package validators

import (
	"fmt"

	"github.com/go-playground/locales/en"
	ut "github.com/go-playground/universal-translator"
	"github.com/go-playground/validator/v10"
	en_translations "github.com/go-playground/validator/v10/translations/en"
	"github.com/gofastadev/gofasta/pkg/validators"
	"gorm.io/gorm"
)

// NewValidator creates and returns a new validator instance with custom error messages
func newValidator(db *gorm.DB) (*validator.Validate, ut.Translator, error) {
	validate := validator.New()

	// Create a universal translator and register English translations
	enLocale := en.New()
	uni := ut.New(enLocale, enLocale)

	trans, found := uni.GetTranslator("en")
	if !found {
		return nil, nil, fmt.Errorf("translator not found")
	}

	// Register English translations
	err := en_translations.RegisterDefaultTranslations(validate, trans)
	if err != nil {
		return nil, nil, err
	}

	for tag, message := range getCustomValidationMessages() {
		if err := validate.RegisterTranslation(tag, trans, func(ut ut.Translator) error {
			return ut.Add(tag, message, true)
		}, func(ut ut.Translator, fe validator.FieldError) string {
			t, _ := ut.T(tag, fe.Field(), fe.Param())
			return t
		}); err != nil {
			return nil, nil, fmt.Errorf("register translation %q: %w", tag, err)
		}
	}

	// COMMON VALIDATORS (from framework)
	validators.RegisterCommonValidators(validate, db)

	// USER VALIDATIONS
	registrations := map[string]validator.Func{
		"is_record_exist_by_email_for_conflict":            isRecordExistByEmailForConflict(db),
		"does_record_exist_by_email_for_verification":      doesRecordExistByEmailForVerification(db),
		"is_record_exist_by_phone_number_for_conflict":     isRecordExistByPhoneNumberForConflict(db),
		"is_record_exist_by_phone_number_for_verification": isRecordExistByPhoneNumberForVerification(db),
		"is_valid_phone_number":                            isValidPhoneNumber,
	}
	for tag, fn := range registrations {
		if err := validate.RegisterValidation(tag, fn); err != nil {
			return nil, nil, fmt.Errorf("register validation %q: %w", tag, err)
		}
	}

	return validate, trans, nil
}

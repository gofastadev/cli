package services

// Domain-shaped inputs for the user service. These are deliberately
// distinct from the wire-shaped DTOs in `app/dtos/`: the DTO is what
// the HTTP/GraphQL surface accepts; this is what the service operates
// on. The controller is the translator (DTO → input) so the service
// stays unaware of any specific transport.

// CreateUserInput is the data required to create a new user. The
// password is generated by the service via PasswordGenerator — callers
// supply the human-facing fields only.
type CreateUserInput struct {
	FirstName   string
	OtherNames  string
	Email       string
	PhoneNumber string
}

// UpdateUserPatch is a partial update — every field is a pointer so
// `nil` means "don't touch this column". AsMap returns the GORM
// `Updates(...)` payload containing only the fields the caller set.
//
// This replaces the older `utils.ConvertStructToMap(input)` pattern,
// which would silently include the input's ID and RecordVersion in
// the SET clause and rewrite them on every update.
type UpdateUserPatch struct {
	FirstName   *string
	OtherNames  *string
	Email       *string
	PhoneNumber *string
	IsActive    *bool
	IsDeletable *bool
}

// AsMap builds the partial-update map for the repository. Only fields
// that the caller set (non-nil pointers) end up in the SET clause —
// every other column is left untouched in the UPDATE statement.
func (p UpdateUserPatch) AsMap() map[string]any {
	out := map[string]any{}
	if p.FirstName != nil {
		out["first_name"] = *p.FirstName
	}
	if p.OtherNames != nil {
		out["other_names"] = *p.OtherNames
	}
	if p.Email != nil {
		out["email"] = *p.Email
	}
	if p.PhoneNumber != nil {
		out["phone_number"] = *p.PhoneNumber
	}
	if p.IsActive != nil {
		out["is_active"] = *p.IsActive
	}
	if p.IsDeletable != nil {
		out["is_deletable"] = *p.IsDeletable
	}
	return out
}

// ListUsersFilter is the typed filter the service accepts for list
// queries. The repository turns this into a `map[string]any` for
// `utils.BuildQueryForAnyModel`; the controller turns the wire DTO
// into this struct.
type ListUsersFilter struct {
	FirstName   *string
	OtherNames  *string
	Email       *string
	PhoneNumber *string

	Page  int
	Limit int

	SortField string // already-sanitized column name; empty → default
	SortDesc  bool   // true → DESC, false → ASC
}

// AsRepoFilter returns the per-column filter map that
// utils.BuildQueryForAnyModel consumes (only present fields).
func (f ListUsersFilter) AsRepoFilter() map[string]any {
	out := map[string]any{}
	if f.FirstName != nil {
		out["first_name"] = *f.FirstName
	}
	if f.OtherNames != nil {
		out["other_names"] = *f.OtherNames
	}
	if f.Email != nil {
		out["email"] = *f.Email
	}
	if f.PhoneNumber != nil {
		out["phone_number"] = *f.PhoneNumber
	}
	return out
}

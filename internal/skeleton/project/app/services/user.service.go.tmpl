package services

import (
	"context"
	"errors"
	"fmt"
	"log/slog"

	"github.com/google/uuid"
	"go.opentelemetry.io/otel"
	"gorm.io/gorm"

	"{{.ModulePath}}/app/models"
	repoInterfaces "{{.ModulePath}}/app/repositories/interfaces"
)

// userServiceTracerName is the OpenTelemetry tracer scope for this
// service. Every method opens a span under this scope so the dev
// dashboard's trace waterfall shows controller → service → repository
// spans nested correctly.
const userServiceTracerName = "{{.ModulePath}}/app/services/user"

// Compile-time check that UserService implements the interface.
// Lives in the parent `services` package because the interface lives
// in `services/interfaces` — it can't reference *UserService directly
// without an import cycle. The wire provider's wire.Bind plays the
// runtime equivalent role.
var _ = (*UserService)(nil)

// UserService implements the user-domain business logic on top of the
// repository layer. Fields are unexported — Wire injects them via the
// constructor; nothing outside this package needs direct access.
//
// Note what's NOT here: no Validator dependency. The controller (and
// graphql resolver) validates input BEFORE calling these methods, so
// this layer can assume its inputs are already valid.
type UserService struct {
	repo  repoInterfaces.UserRepositoryInterface
	pwGen PasswordGenerator
}

// NewUserService constructs a UserService. Wire calls this at app
// startup, satisfying the dependencies from the project's wire set.
func NewUserService(repo repoInterfaces.UserRepositoryInterface, pwGen PasswordGenerator) *UserService {
	return &UserService{repo: repo, pwGen: pwGen}
}

// List returns the paginated set of users matching the filter, plus
// the total count for pagination.
func (s *UserService) List(ctx context.Context, filter ListUsersFilter) ([]*models.User, int64, error) {
	ctx, span := otel.Tracer(userServiceTracerName).Start(ctx, "UserService.List")
	defer span.End()

	sort := buildSortClause(filter.SortField, filter.SortDesc)
	users, total, err := s.repo.List(ctx, filter.AsRepoFilter(), filter.Page, filter.Limit, sort)
	if err != nil {
		span.RecordError(err)
		return nil, 0, fmt.Errorf("UserService.List: %w", err)
	}
	return users, total, nil
}

// Get returns the user identified by id, or ErrUserNotFound if no row
// matches. Infrastructure failures bubble up wrapped.
func (s *UserService) Get(ctx context.Context, id uuid.UUID) (*models.User, error) {
	ctx, span := otel.Tracer(userServiceTracerName).Start(ctx, "UserService.Get")
	defer span.End()

	user, err := s.repo.FindByID(ctx, id)
	if errors.Is(err, gorm.ErrRecordNotFound) {
		return nil, ErrUserNotFound
	}
	if err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.Get: %w", err)
	}
	return user, nil
}

// Create persists a new user with a freshly-generated password. The
// service owns password generation so callers can't accidentally
// supply a weak one — the wire-shaped CreateUserDto has no Password
// field for this reason.
func (s *UserService) Create(ctx context.Context, in CreateUserInput) (*models.User, error) {
	ctx, span := otel.Tracer(userServiceTracerName).Start(ctx, "UserService.Create")
	defer span.End()

	pw, err := s.pwGen.Generate(16)
	if err != nil {
		span.RecordError(err)
		slog.ErrorContext(ctx, "failed to generate random password", "error", err)
		return nil, fmt.Errorf("UserService.Create: generate password: %w", err)
	}

	user := &models.User{
		FirstName:   in.FirstName,
		OtherNames:  in.OtherNames,
		Email:       in.Email,
		PhoneNumber: in.PhoneNumber,
		Password:    pw,
	}
	if err := s.repo.Create(ctx, user); err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.Create: persist: %w", err)
	}
	return user, nil
}

// Update applies a partial update under optimistic locking. The
// version check + UPDATE + refetch all happen in one transaction
// inside the repo, so the returned *models.User is exactly what THIS
// update wrote (snapshot semantics — no other writer can race in
// between).
//
// Returns ErrUserVersionConflict when the expectedVersion no longer
// matches the persisted value.
func (s *UserService) Update(ctx context.Context, id uuid.UUID, expectedVersion int, patch UpdateUserPatch) (*models.User, error) {
	ctx, span := otel.Tracer(userServiceTracerName).Start(ctx, "UserService.Update")
	defer span.End()

	user, affected, err := s.repo.UpdateIfVersionMatches(ctx, id, expectedVersion, patch.AsMap())
	if err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.Update: %w", err)
	}
	if affected == 0 {
		return nil, ErrUserVersionConflict
	}
	return user, nil
}

// Archive soft-deletes the user and returns the soft-deleted record so
// the caller can respond 200-with-payload (the Stripe pattern). The
// repo's transaction reads + classifies + writes atomically — three
// outcomes the controller maps to distinct HTTP statuses:
//
//   - ErrUserNotFound — row missing OR already soft-deleted (404).
//   - ErrUserNotDeletable — row exists but IsDeletable=false (409).
//   - (*models.User, nil) — soft-deleted; payload contains the
//     freshly-stamped deleted_at + is_active=false.
func (s *UserService) Archive(ctx context.Context, id uuid.UUID) (*models.User, error) {
	ctx, span := otel.Tracer(userServiceTracerName).Start(ctx, "UserService.Archive")
	defer span.End()

	user, err := s.repo.SoftDeleteIfDeletable(ctx, id)
	switch {
	case errors.Is(err, gorm.ErrRecordNotFound):
		return nil, ErrUserNotFound
	case errors.Is(err, repoInterfaces.ErrUserNotDeletable):
		return nil, ErrUserNotDeletable
	case err != nil:
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.Archive: %w", err)
	}
	return user, nil
}

// buildSortClause turns the typed sort intent into the string GORM
// expects. The caller (controller) has already sanitized SortField
// (whitelist or regex) — this function just composes the clause.
func buildSortClause(field string, desc bool) string {
	if field == "" {
		field = "created_at"
	}
	if desc {
		return field + " DESC"
	}
	return field + " ASC"
}

package services

import (
	"context"
	"errors"
	"fmt"
	"log/slog"
	"math"
	"net/http"

	"github.com/gofastadev/gofasta/pkg/utils"
	"go.opentelemetry.io/otel"
	"gorm.io/gorm"

	"{{.ModulePath}}/app/dtos"
	"{{.ModulePath}}/app/models"
	repoInterfaces "{{.ModulePath}}/app/repositories/interfaces"
	svcInterfaces "{{.ModulePath}}/app/services/interfaces"
	"{{.ModulePath}}/app/validators"
)

// userServiceTracerName is the OpenTelemetry tracer scope for this
// service. Every method opens a span under this scope so the dev
// dashboard's trace waterfall shows a proper controller → service →
// repository breakdown. Matches the pattern `gofasta g service` emits
// for newly generated resources.
const userServiceTracerName = "{{.ModulePath}}/app/services/user"

// Compile-time check that UserService implements UserServiceInterface.
var _ svcInterfaces.UserServiceInterface = (*UserService)(nil)

// UserService implements the user-domain business logic on top of the
// repository layer. It owns input validation, optimistic-locking checks,
// and the model→DTO mapping the controller returns to clients.
type UserService struct {
	UserRepo  repoInterfaces.UserRepositoryInterface
	Validator *validators.AppValidator
}

// NewUserService constructs a UserService bound to the supplied
// repository + validator. Wire calls this at app startup.
func NewUserService(userRepo repoInterfaces.UserRepositoryInterface, appValidator *validators.AppValidator) *UserService {
	return &UserService{
		UserRepo:  userRepo,
		Validator: appValidator,
	}
}

// FindUsersWithFilters returns the paginated set of users matching the
// supplied filters, alongside pagination metadata the client needs to
// render page controls.
func (u *UserService) FindUsersWithFilters(ctx context.Context, filters dtos.UserFiltersDto) (*dtos.TUsersResponseDto, error) {
	ctx, span := otel.Tracer(userServiceTracerName).Start(ctx, "UserService.FindUsersWithFilters")
	defer span.End()

	paginator := utils.PreparePaginating{PageFilters: filters.Pagination, Sorting: filters.Sorting}
	page := paginator.GetPage()
	limit := paginator.GetLimit()
	sort := paginator.GetSort()

	filterMap := utils.ConvertStructToMap(filters.Fields)
	users, totalCount, err := u.UserRepo.FindWithFilters(ctx, filterMap, page, limit, sort)
	if err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.FindUsersWithFilters: %w", err)
	}

	// Convert models to DTOs
	userDtos := make([]*dtos.User, 0, len(users))
	for _, user := range users {
		userDtos = append(userDtos, castUserModelToUserDto(user))
	}

	totalRecords := int(totalCount)
	totalPages := int(math.Ceil(float64(totalCount) / float64(limit)))
	return &dtos.TUsersResponseDto{
		Data: userDtos,
		Pagination: &dtos.TPaginationObjectDto{
			TotalRecords:   &totalRecords,
			CurrentPage:    &page,
			RecordsPerPage: &limit,
			TotalPages:     &totalPages,
		},
	}, nil
}

// CreateUser validates the input, generates a random initial password,
// inserts the user, and returns the freshly-persisted record. Validation
// failures come back as Errors in the response (HTTP 200 with a body)
// rather than as a Go error — only infrastructure failures bubble up.
func (u *UserService) CreateUser(ctx context.Context, input dtos.TCreateUserDto) (*dtos.TUserResponseDto, error) {
	ctx, span := otel.Tracer(userServiceTracerName).Start(ctx, "UserService.CreateUser")
	defer span.End()

	if validationErrors := u.Validator.ValidateStruct(input); len(validationErrors) > 0 {
		return &dtos.TUserResponseDto{Errors: validationErrors}, nil
	}
	randomPassword, err := utils.GeneratePassword(16)
	if err != nil {
		span.RecordError(err)
		slog.ErrorContext(ctx, "failed to generate random password", "error", err)
		return nil, fmt.Errorf("UserService.CreateUser: generate password: %w", err)
	}
	userData := &models.User{
		FirstName:   input.FirstName,
		OtherNames:  input.OtherNames,
		PhoneNumber: input.PhoneNumber,
		Email:       input.Email,
		Password:    randomPassword,
	}
	if err := u.UserRepo.Create(ctx, userData); err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.CreateUser: persist: %w", err)
	}
	return &dtos.TUserResponseDto{Data: castUserModelToUserDto(userData)}, nil
}

// UpdateUser applies a partial update under optimistic locking. The
// caller's RecordVersion must match the persisted version or the update
// is rejected with a structured error — preventing two concurrent edits
// from silently overwriting each other.
func (u *UserService) UpdateUser(ctx context.Context, input dtos.TUserFieldsForUpdateDto) (*dtos.TUserResponseDto, error) {
	ctx, span := otel.Tracer(userServiceTracerName).Start(ctx, "UserService.UpdateUser")
	defer span.End()

	if validationErrors := u.Validator.ValidateStruct(input); len(validationErrors) > 0 {
		return &dtos.TUserResponseDto{Errors: validationErrors}, nil
	}
	// Optimistic-locking guard: only proceed if the persisted version
	// still matches what the caller saw. We DISTINGUISH "not found
	// because the version changed" (gorm.ErrRecordNotFound) from "the
	// DB blew up" (any other error) — the original code treated both
	// as "wrong version", masking infrastructure failures as user errors.
	userToUpd, err := u.UserRepo.FindByIDAndRecordVersion(ctx, input.ID, input.RecordVersion)
	if err != nil && !errors.Is(err, gorm.ErrRecordNotFound) {
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.UpdateUser: lock check: %w", err)
	}
	if userToUpd == nil || errors.Is(err, gorm.ErrRecordNotFound) {
		fieldName := "recordVersion"
		return &dtos.TUserResponseDto{Errors: []*dtos.TCommonAPIErrorDto{
			{FieldName: &fieldName, Message: "The record version you passed is not matching"},
		}}, nil
	}
	userDataForUpdate := utils.ConvertStructToMap(input)
	if err := u.UserRepo.Update(ctx, input.ID, userDataForUpdate); err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.UpdateUser: persist: %w", err)
	}
	foundUser, err := u.UserRepo.FindByID(ctx, input.ID)
	if err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.UpdateUser: refetch: %w", err)
	}
	return &dtos.TUserResponseDto{Data: castUserModelToUserDto(foundUser)}, nil
}

// FindUserByID returns the user identified by filters.UserID. Returns
// validation errors in-band; surfaces repository errors as Go errors.
func (u *UserService) FindUserByID(ctx context.Context, filters dtos.TFindUserByIDDto) (*dtos.TUserResponseDto, error) {
	ctx, span := otel.Tracer(userServiceTracerName).Start(ctx, "UserService.FindUserByID")
	defer span.End()

	if validationErrors := u.Validator.ValidateStruct(filters); len(validationErrors) > 0 {
		return &dtos.TUserResponseDto{Errors: validationErrors}, nil
	}
	user, err := u.UserRepo.FindByID(ctx, filters.UserID)
	if err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.FindUserByID: %w", err)
	}
	return &dtos.TUserResponseDto{Data: castUserModelToUserDto(user)}, nil
}

// ArchiveUser soft-deletes the user identified by input.UserID, after
// running the is_record_deletable validator to guard rows that should
// not be archivable (system accounts, etc.).
func (u *UserService) ArchiveUser(ctx context.Context, input dtos.TArchiveUserDto) (*dtos.TCommonResponseDto, error) {
	ctx, span := otel.Tracer(userServiceTracerName).Start(ctx, "UserService.ArchiveUser")
	defer span.End()

	if validationErrors := u.Validator.ValidateStruct(input); len(validationErrors) > 0 {
		return &dtos.TCommonResponseDto{Errors: validationErrors}, nil
	}
	if err := u.UserRepo.SoftDelete(ctx, input.UserID); err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserService.ArchiveUser: %w", err)
	}
	status := http.StatusOK
	message := "Success"
	return &dtos.TCommonResponseDto{Status: status, Message: &message}, nil
}

// castUserModelToUserDto maps a persisted User onto its public-facing
// DTO. The mapping is total and infallible — callers don't need to
// handle errors. If a future field requires conversion that can fail,
// reintroduce an error return at that point.
func castUserModelToUserDto(user *models.User) *dtos.User {
	dto := &dtos.User{
		ID:            user.ID,
		RecordVersion: user.RecordVersion,
		FirstName:     user.FirstName,
		OtherNames:    user.OtherNames,
		PhoneNumber:   user.PhoneNumber,
		Email:         user.Email,
		CreatedAt:     user.CreatedAt,
		UpdatedAt:     user.UpdatedAt,
		IsActive:      user.IsActive,
		IsDeletable:   user.IsDeletable,
	}
	// Only surface DeletedAt when the row has actually been soft-
	// deleted (gorm.DeletedAt.Valid == true). A non-nil pointer to a
	// zero time would render as "0001-01-01T00:00:00Z" in JSON instead
	// of being omitted via the omitempty tag.
	if user.DeletedAt.Valid {
		t := user.DeletedAt.Time
		dto.DeletedAt = &t
	}
	return dto
}

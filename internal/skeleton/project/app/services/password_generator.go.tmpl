package services

import "github.com/gofastadev/gofasta/pkg/utils"

// PasswordGenerator produces a random password of the given length.
// The interface exists so tests can stub the random source — the
// production implementation wraps the framework's
// `utils.GeneratePassword`, which uses crypto/rand.
type PasswordGenerator interface {
	Generate(length int) (string, error)
}

// DefaultPasswordGenerator is the production implementation.
type DefaultPasswordGenerator struct{}

// NewDefaultPasswordGenerator is the Wire provider for PasswordGenerator.
func NewDefaultPasswordGenerator() PasswordGenerator {
	return DefaultPasswordGenerator{}
}

// Generate delegates to utils.GeneratePassword.
func (DefaultPasswordGenerator) Generate(length int) (string, error) {
	return utils.GeneratePassword(length)
}

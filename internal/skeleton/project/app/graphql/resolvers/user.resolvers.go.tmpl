package resolvers

// Per gqlgen convention, this file is regenerated by
// `go tool gqlgen generate` from the .graphql schema; resolver bodies
// you write here are preserved across regenerations.

import (
	"context"
	"errors"

	"github.com/vektah/gqlparser/v2/gqlerror"
	"gorm.io/gorm"

	"{{.ModulePath}}/app/dtos"
	"{{.ModulePath}}/app/services"
)

// CreateUser is the resolver for the createUser field.
func (r *mutationResolver) CreateUser(ctx context.Context, input dtos.TCreateUserDto) (*dtos.User, error) {
	if errs := r.Validator.ValidateStruct(input); len(errs) > 0 {
		return nil, validationGqlError(errs)
	}
	user, err := r.UserService.Create(ctx, input.ToCreateInput())
	if err != nil {
		return nil, internalGqlError("failed to create user", err)
	}
	return dtos.UserFromModel(user), nil
}

// UpdateUser is the resolver for the updateUser field.
func (r *mutationResolver) UpdateUser(ctx context.Context, input dtos.TUpdateUserDto) (*dtos.User, error) {
	if errs := r.Validator.ValidateStruct(input); len(errs) > 0 {
		return nil, validationGqlError(errs)
	}
	user, err := r.UserService.Update(ctx, input.ID, input.RecordVersion, input.ToPatch())
	switch {
	case errors.Is(err, services.ErrUserVersionConflict):
		return nil, gqlError("CONFLICT", "record version mismatch — refetch and retry")
	case errors.Is(err, services.ErrUserNotFound), errors.Is(err, gorm.ErrRecordNotFound):
		return nil, gqlError("NOT_FOUND", "user not found")
	case err != nil:
		return nil, internalGqlError("failed to update user", err)
	}
	return dtos.UserFromModel(user), nil
}

// ArchiveUser is the resolver for the archiveUser field.
func (r *mutationResolver) ArchiveUser(ctx context.Context, input dtos.TArchiveUserDto) (bool, error) {
	if errs := r.Validator.ValidateStruct(input); len(errs) > 0 {
		return false, validationGqlError(errs)
	}
	err := r.UserService.Archive(ctx, input.UserID)
	switch {
	case errors.Is(err, services.ErrUserNotDeletable):
		return false, gqlError("CONFLICT", "user is not deletable")
	case err != nil:
		return false, internalGqlError("failed to archive user", err)
	}
	return true, nil
}

// FindUsersWithFilters is the resolver for the users field.
func (r *queryResolver) FindUsersWithFilters(ctx context.Context, filters dtos.TUserFiltersQueryParamsDto) (*dtos.TUsersResponseDto, error) {
	if errs := r.Validator.ValidateStruct(filters); len(errs) > 0 {
		return nil, validationGqlError(errs)
	}
	f := filters.ToFilter()
	users, total, err := r.UserService.List(ctx, f)
	if err != nil {
		return nil, internalGqlError("failed to list users", err)
	}
	totalRecords := int(total)
	totalPages := 0
	if f.Limit > 0 {
		totalPages = (totalRecords + f.Limit - 1) / f.Limit
	}
	return &dtos.TUsersResponseDto{
		Data: dtos.UsersFromModels(users),
		Pagination: &dtos.TPaginationObjectDto{
			TotalRecords:   &totalRecords,
			CurrentPage:    &f.Page,
			RecordsPerPage: &f.Limit,
			TotalPages:     &totalPages,
		},
	}, nil
}

// FindUserByID is the resolver for the findUserById field.
func (r *queryResolver) FindUserByID(ctx context.Context, filters dtos.TFindUserByIDDto) (*dtos.User, error) {
	if errs := r.Validator.ValidateStruct(filters); len(errs) > 0 {
		return nil, validationGqlError(errs)
	}
	user, err := r.UserService.Get(ctx, filters.UserID)
	switch {
	case errors.Is(err, services.ErrUserNotFound), errors.Is(err, gorm.ErrRecordNotFound):
		return nil, gqlError("NOT_FOUND", "user not found")
	case err != nil:
		return nil, internalGqlError("failed to find user", err)
	}
	return dtos.UserFromModel(user), nil
}

// gqlError builds a structured GraphQL error with a stable `code`
// extension so clients can branch on it.
func gqlError(code, message string) *gqlerror.Error {
	return &gqlerror.Error{
		Message:    message,
		Extensions: map[string]any{"code": code},
	}
}

// validationGqlError translates the framework's validation result into
// a GraphQL error with per-field details under `extensions.fields`.
func validationGqlError(errs []*dtos.TCommonAPIErrorDto) *gqlerror.Error {
	fields := make([]map[string]any, 0, len(errs))
	for _, e := range errs {
		field := map[string]any{"message": e.Message}
		if e.FieldName != nil {
			field["fieldName"] = *e.FieldName
		}
		fields = append(fields, field)
	}
	return &gqlerror.Error{
		Message: "invalid input",
		Extensions: map[string]any{
			"code":   "VALIDATION_FAILED",
			"fields": fields,
		},
	}
}

// internalGqlError surfaces the underlying error for log correlation
// without leaking it in the public message field. The extension's
// `code` is stable; the wrapped error is preserved via Err so log
// scrapers can dig in.
func internalGqlError(message string, err error) *gqlerror.Error {
	gqlErr := &gqlerror.Error{
		Message:    message,
		Extensions: map[string]any{"code": "INTERNAL"},
	}
	gqlErr.Err = err
	return gqlErr
}


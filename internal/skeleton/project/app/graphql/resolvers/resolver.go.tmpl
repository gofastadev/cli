package resolvers

import svcInterfaces "{{.ModulePath}}/app/services/interfaces"

// This file holds the dependency-injected Resolver struct. The
// Mutation()/Query() entry points and the concrete *mutationResolver /
// *queryResolver value types are emitted by `go tool gqlgen generate`
// into a sibling .resolvers.go file (gqlgen v0.17.90 emits them at the
// bottom of whichever schema file owns the first mutation/query —
// typically server.health.resolvers.go). Keeping them out of this file
// avoids duplicate-symbol conflicts after each codegen run.

type Resolver struct {
	UserService svcInterfaces.UserServiceInterface
}

// NewResolver creates a new Resolver with the provided service dependencies.
func NewResolver(userService svcInterfaces.UserServiceInterface) *Resolver {
	return &Resolver{UserService: userService}
}

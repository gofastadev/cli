package repositories

import (
	"context"
	"fmt"
	"time"

	"github.com/gofastadev/gofasta/pkg/utils"
	"github.com/google/uuid"
	"go.opentelemetry.io/otel"
	"gorm.io/gorm"

	"{{.ModulePath}}/app/models"
	repoInterfaces "{{.ModulePath}}/app/repositories/interfaces"
)

// userRepositoryTracerName is the OpenTelemetry tracer scope for this
// repository. Each method opens a span so the dev dashboard can show
// data-access calls as nested bars under the service span. Matches the
// `gofasta g repository` pattern so custom and scaffolded repos group
// uniformly in the trace view.
const userRepositoryTracerName = "{{.ModulePath}}/app/repositories/user"

// Compile-time check that UserRepository implements UserRepositoryInterface.
var _ repoInterfaces.UserRepositoryInterface = (*UserRepository)(nil)

// UserRepository is the GORM-backed data-access layer for the User
// resource. Methods open OpenTelemetry spans for each call so they show
// up nested under their service span in the trace view.
type UserRepository struct {
	DB *gorm.DB
}

// NewUserRepository constructs a UserRepository bound to the supplied
// GORM database handle. Wire calls this at app startup.
func NewUserRepository(db *gorm.DB) *UserRepository {
	return &UserRepository{DB: db}
}

// FindWithFilters returns the paginated set of users matching `filters`,
// sorted by `sort`, along with the total count for pagination. The
// filter map keys map directly to column names via utils.BuildQueryForAnyModel.
//
// Soft-deleted rows are excluded automatically because BaseModelImpl's
// DeletedAt is gorm.DeletedAt — every SELECT gets a `WHERE deleted_at
// IS NULL` clause from GORM. To include archived rows, callers can
// build a query with .Unscoped() and pass that here instead.
func (r *UserRepository) FindWithFilters(ctx context.Context, filters map[string]any, page, limit int, sort string) ([]*models.User, int64, error) {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.FindWithFilters")
	defer span.End()

	query, err := utils.BuildQueryForAnyModel(r.DB.WithContext(ctx).Model(&models.User{}), filters)
	if err != nil {
		span.RecordError(err)
		return nil, 0, fmt.Errorf("UserRepository.FindWithFilters: build query: %w", err)
	}

	var totalCount int64
	if err := query.Count(&totalCount).Error; err != nil {
		span.RecordError(err)
		return nil, 0, fmt.Errorf("UserRepository.FindWithFilters: count: %w", err)
	}

	offset := (page - 1) * limit
	var users []*models.User
	if err := query.Limit(limit).Offset(offset).Order(sort).Find(&users).Error; err != nil {
		span.RecordError(err)
		return nil, 0, fmt.Errorf("UserRepository.FindWithFilters: query: %w", err)
	}

	return users, totalCount, nil
}

// Create inserts a new user row. The framework's BeforeCreate hook on
// BaseModelImpl populates the UUID and timestamps automatically.
func (r *UserRepository) Create(ctx context.Context, user *models.User) error {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.Create")
	defer span.End()

	if err := r.DB.WithContext(ctx).Create(user).Error; err != nil {
		span.RecordError(err)
		return fmt.Errorf("UserRepository.Create: %w", err)
	}
	return nil
}

// Update applies a partial update to the user identified by `id`. Only
// keys present in the `fields` map are written, so callers can pass
// just the deltas they want to change.
func (r *UserRepository) Update(ctx context.Context, id uuid.UUID, fields map[string]any) error {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.Update")
	defer span.End()

	if err := r.DB.WithContext(ctx).Model(&models.User{}).Where("id = ?", id).Updates(fields).Error; err != nil {
		span.RecordError(err)
		return fmt.Errorf("UserRepository.Update: %w", err)
	}
	return nil
}

// FindByID returns the user with the given ID. Returns gorm.ErrRecordNotFound
// when no row matches (including when soft-deleted — the auto-filter
// on gorm.DeletedAt excludes deleted rows).
func (r *UserRepository) FindByID(ctx context.Context, id uuid.UUID) (*models.User, error) {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.FindByID")
	defer span.End()

	var user models.User
	if err := r.DB.WithContext(ctx).Where("id = ?", id).First(&user).Error; err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserRepository.FindByID: %w", err)
	}
	return &user, nil
}

// FindByIDAndRecordVersion returns the user with the given ID only if
// its RecordVersion matches `version`. Used by the optimistic-locking
// path on updates — the service compares the caller's expected
// version with the database before committing a change.
//
// Soft-deleted rows are excluded automatically by GORM's auto-filter
// on gorm.DeletedAt; no manual `WHERE deleted_at IS NULL` is needed.
func (r *UserRepository) FindByIDAndRecordVersion(ctx context.Context, id uuid.UUID, version int) (*models.User, error) {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.FindByIDAndRecordVersion")
	defer span.End()

	var user models.User
	if err := r.DB.WithContext(ctx).Where("id = ? AND record_version = ?", id, version).First(&user).Error; err != nil {
		span.RecordError(err)
		return nil, fmt.Errorf("UserRepository.FindByIDAndRecordVersion: %w", err)
	}
	return &user, nil
}

// SoftDelete marks the user as deleted by setting deleted_at + clearing
// is_active in a single UPDATE. The is_deletable guard prevents
// archiving protected rows (system accounts, etc.). Setting deleted_at
// directly works alongside gorm.DeletedAt — GORM's auto-filter then
// excludes the row from subsequent reads.
func (r *UserRepository) SoftDelete(ctx context.Context, id uuid.UUID) error {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.SoftDelete")
	defer span.End()

	if err := r.DB.WithContext(ctx).Model(&models.User{}).
		Where("id = ? AND is_deletable = ?", id, true).
		Updates(map[string]any{"deleted_at": time.Now(), "is_active": false}).Error; err != nil {
		span.RecordError(err)
		return fmt.Errorf("UserRepository.SoftDelete: %w", err)
	}
	return nil
}

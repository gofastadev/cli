package repositories

import (
	"context"
	"time"

	"github.com/google/uuid"
	"{{.ModulePath}}/app/models"
	repoInterfaces "{{.ModulePath}}/app/repositories/interfaces"
	"github.com/gofastadev/gofasta/pkg/utils"
	"go.opentelemetry.io/otel"
	"gorm.io/gorm"
)

// userRepositoryTracerName is the OpenTelemetry tracer scope for this
// repository. Each method opens a span so the dev dashboard can show
// data-access calls as nested bars under the service span. Matches the
// `gofasta g repository` pattern so custom and scaffolded repos group
// uniformly in the trace view.
const userRepositoryTracerName = "{{.ModulePath}}/app/repositories/user"

// Compile-time check that UserRepository implements UserRepositoryInterface.
var _ repoInterfaces.UserRepositoryInterface = (*UserRepository)(nil)

type UserRepository struct {
	DB *gorm.DB
}

func NewUserRepository(db *gorm.DB) *UserRepository {
	return &UserRepository{DB: db}
}

func (r *UserRepository) FindWithFilters(ctx context.Context, filters map[string]interface{}, page, limit int, sort string) ([]*models.User, int64, error) {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.FindWithFilters")
	defer span.End()

	query, err := utils.BuildQueryForAnyModel(r.DB.WithContext(ctx).Model(&models.User{}), filters)
	if err != nil {
		span.RecordError(err)
		return nil, 0, err
	}

	var totalCount int64
	if err := query.Count(&totalCount).Error; err != nil {
		span.RecordError(err)
		return nil, 0, err
	}

	offset := (page - 1) * limit
	var users []*models.User
	if err := query.Limit(limit).Offset(offset).Order(sort).Find(&users).Error; err != nil {
		span.RecordError(err)
		return nil, 0, err
	}

	return users, totalCount, nil
}

func (r *UserRepository) Create(ctx context.Context, user *models.User) error {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.Create")
	defer span.End()

	if err := r.DB.WithContext(ctx).Create(user).Error; err != nil {
		span.RecordError(err)
		return err
	}
	return nil
}

func (r *UserRepository) Update(ctx context.Context, id uuid.UUID, fields map[string]interface{}) error {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.Update")
	defer span.End()

	if err := r.DB.WithContext(ctx).Model(&models.User{}).Where("id = ?", id).Updates(fields).Error; err != nil {
		span.RecordError(err)
		return err
	}
	return nil
}

func (r *UserRepository) FindByID(ctx context.Context, id uuid.UUID) (*models.User, error) {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.FindByID")
	defer span.End()

	var user models.User
	if err := r.DB.WithContext(ctx).Where("id = ?", id).First(&user).Error; err != nil {
		span.RecordError(err)
		return nil, err
	}
	return &user, nil
}

func (r *UserRepository) FindByIDAndRecordVersion(ctx context.Context, id uuid.UUID, version int) (*models.User, error) {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.FindByIDAndRecordVersion")
	defer span.End()

	var user models.User
	if err := r.DB.WithContext(ctx).Where("id = ? AND deleted_at IS NULL AND record_version = ?", id, version).First(&user).Error; err != nil {
		span.RecordError(err)
		return nil, err
	}
	return &user, nil
}

func (r *UserRepository) SoftDelete(ctx context.Context, id uuid.UUID) error {
	ctx, span := otel.Tracer(userRepositoryTracerName).Start(ctx, "UserRepository.SoftDelete")
	defer span.End()

	if err := r.DB.WithContext(ctx).Model(&models.User{}).
		Where("id = ? AND is_deletable = ?", id, true).
		Updates(map[string]interface{}{"deleted_at": time.Now(), "is_active": false}).Error; err != nil {
		span.RecordError(err)
		return err
	}
	return nil
}

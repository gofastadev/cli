package interfaces

import (
	"context"

	"github.com/google/uuid"

	"{{.ModulePath}}/app/models"
)

// UserRepositoryInterface is the persistence contract for users.
//
// Two methods (UpdateIfVersionMatches, SoftDeleteIfDeletable) bake the
// business preconditions into the SQL WHERE clause so the operations
// are atomic — there's no Find-then-Update gap for another writer to
// race through. Both return RowsAffected; callers map 0 to a domain
// sentinel error.
type UserRepositoryInterface interface {
	// List returns the paginated, sorted, filtered set of users.
	// `filter` is the per-column ILIKE map (typically built from
	// services.ListUsersFilter.AsRepoFilter()). `sort` is a
	// pre-sanitized "<column> ASC|DESC" string from
	// `utils.PreparePaginating.GetSort()`.
	List(ctx context.Context, filter map[string]any, page, limit int, sort string) ([]*models.User, int64, error)

	// FindByID returns one user by primary key. Soft-deleted rows are
	// excluded automatically by GORM's gorm.DeletedAt auto-filter.
	// Returns gorm.ErrRecordNotFound when no row matches.
	FindByID(ctx context.Context, id uuid.UUID) (*models.User, error)

	// Create inserts a new user row. The framework's BeforeCreate hook
	// on BaseModelImpl sets the UUID, timestamps, and defaults.
	Create(ctx context.Context, user *models.User) error

	// UpdateIfVersionMatches runs an atomic UPDATE with the version
	// check folded into the WHERE clause, then refetches the row in
	// the same transaction so the returned *models.User is exactly
	// what THIS update wrote (snapshot semantics).
	//
	// Returns:
	//   (user, 1, nil) — success
	//   (nil, 0, nil)  — version didn't match (caller maps to ErrUserVersionConflict)
	//   (nil, 0, err)  — infrastructure failure
	UpdateIfVersionMatches(ctx context.Context, id uuid.UUID, expectedVersion int, fields map[string]any) (*models.User, int64, error)

	// SoftDeleteIfDeletable runs an atomic UPDATE with the deletable
	// guard in the WHERE clause. Returns RowsAffected; 0 means the
	// row was missing OR not deletable (caller maps to
	// ErrUserNotDeletable / ErrUserNotFound depending on policy).
	SoftDeleteIfDeletable(ctx context.Context, id uuid.UUID) (int64, error)
}

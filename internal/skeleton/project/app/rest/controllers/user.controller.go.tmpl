package controllers

import (
	"errors"
	"net/http"
	"strconv"

	"github.com/go-chi/chi/v5"
	apperrors "github.com/gofastadev/gofasta/pkg/errors"
	"github.com/gofastadev/gofasta/pkg/httputil"
	"github.com/gofastadev/gofasta/pkg/utils"
	"gorm.io/gorm"

	"{{.ModulePath}}/app/dtos"

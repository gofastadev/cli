// noopValidator passes every input. Most controller tests use it
// because they're asserting the controller's sentinel→status mapping
// (404, 409, etc.) — making validation pass-through lets the request
// reach the service mock that returns the sentinel under test. Tests
// that exercise validation behavior itself use newRealTestValidator
// instead (see TestCreateUser_ValidationFails_422).
type noopValidator struct{}

func (noopValidator) ValidateStruct(_ any) []*dtos.TCommonAPIErrorDto { return nil }

// newRealTestValidator constructs the project's real AppValidator
// backed by an in-memory SQLite. Custom DB-backed validators
// (does_record_exist_by_id_for_verification, etc.) run against the
// empty DB — call only from tests that want validation to actually
// run, e.g. asserting that bad input produces 422. Helpers that pass
// noopValidator{} skip this setup entirely.
func newRealTestValidator(t *testing.T) *validators.AppValidator {
	t.Helper()
	db, err := gorm.Open(sqlite.Open(":memory:"), &gorm.Config{})
	require.NoError(t, err)
	require.NoError(t, db.AutoMigrate(&models.User{}))
	return validators.NewAppValidator(db)
}

// mountController wires the controller methods onto a chi router via
// httputil.Handle so error returns translate to HTTP status codes the
// way they would in production.
func mountController(c *controllers.UserController) http.Handler {
	r := chi.NewRouter()
	r.Get("/users", httputil.Handle(c.ListUsers))
	r.Post("/users", httputil.Handle(c.CreateUser))
	r.Get("/users/{id}", httputil.Handle(c.GetUser))
	r.Put("/users/{id}", httputil.Handle(c.UpdateUser))
	r.Delete("/users/{id}", httputil.Handle(c.ArchiveUser))
	return r
}

func validUserModel(id uuid.UUID) *models.User {
	u := &models.User{
		FirstName:   "Alice",
		OtherNames:  "X",
		Email:       "alice@example.com",
		PhoneNumber: "0712345678",
	}
	u.ID = id
	u.RecordVersion = 1
	u.IsActive = true
	u.IsDeletable = true
	return u
}

// ── CreateUser ────────────────────────────────────────────────────────

// TestCreateUser_Created_201 — happy path returns 201 with the user
// payload wrapped in {data: ...}.
func TestCreateUser_Created_201(t *testing.T) {
	svc := &mocks.MockUserService{}
	id := uuid.New()
	svc.On("Create", mock.Anything, mock.Anything).Return(validUserModel(id), nil)

	c := controllers.NewUserControllerInstance(svc, noopValidator{})
	body := `{"firstName":"Alice","otherNames":"X","email":"alice@example.com","phoneNumber":"0712345678"}`
	req := httptest.NewRequest(http.MethodPost, "/users", bytes.NewBufferString(body))
	req.Header.Set("Content-Type", "application/json")
	rec := httptest.NewRecorder()
	mountController(c).ServeHTTP(rec, req)

	require.Equal(t, http.StatusCreated, rec.Code)
	var out struct {
		Data *dtos.User `json:"data"`
	}
	require.NoError(t, json.Unmarshal(rec.Body.Bytes(), &out))
	require.NotNil(t, out.Data)
	assert.Equal(t, id, out.Data.ID)
}

// TestCreateUser_ValidationFails_422 — invalid input body must NOT
// reach the service; status is 422 with structured details. Uses the
// REAL AppValidator (not noopValidator) because the assertion is
// specifically about validation behavior.
func TestCreateUser_ValidationFails_422(t *testing.T) {
	svc := &mocks.MockUserService{}
	c := controllers.NewUserControllerInstance(svc, newRealTestValidator(t))

	// Email field missing → required validator fails.
	body := `{"firstName":"A","otherNames":"X","phoneNumber":"0712345678"}`
	req := httptest.NewRequest(http.MethodPost, "/users", bytes.NewBufferString(body))
	req.Header.Set("Content-Type", "application/json")
	rec := httptest.NewRecorder()
	mountController(c).ServeHTTP(rec, req)

	assert.Equal(t, http.StatusUnprocessableEntity, rec.Code)
	svc.AssertNotCalled(t, "Create")
}

// TestCreateUser_BadJSON_400 — malformed body fails BindJSON; 400.
func TestCreateUser_BadJSON_400(t *testing.T) {

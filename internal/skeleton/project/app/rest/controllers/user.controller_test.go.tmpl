// TestListUsers_DefaultsAppliedWhenQueryEmpty — verify the controller
// builds a filter with the right defaults (page=1, limit=10, sort=created_at DESC).
func TestListUsers_DefaultsAppliedWhenQueryEmpty(t *testing.T) {
	svc := &mocks.MockUserService{}
	var captured services.ListUsersFilter
	svc.On("List", mock.Anything, mock.MatchedBy(func(f services.ListUsersFilter) bool {
		captured = f
		return true
	})).Return([]*models.User{}, int64(0), nil)

	c := controllers.NewUserControllerInstance(svc, noopValidator{})
	req := httptest.NewRequest(http.MethodGet, "/users", nil)
	rec := httptest.NewRecorder()
	mountController(c).ServeHTTP(rec, req)

	require.Equal(t, http.StatusOK, rec.Code)
	assert.Equal(t, 1, captured.Page, "default page should be 1")
	assert.Equal(t, 10, captured.Limit, "default limit should be 10")
	assert.Equal(t, "created_at", captured.SortField, "default sort field should be created_at")
	assert.True(t, captured.SortDesc, "default orientation should be DESC")
}


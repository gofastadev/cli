// ── UpdateUser ────────────────────────────────────────────────────────

// makeUpdateReq is the shared request builder for UpdateUser tests.
// Centralizes the body shape (no id, no recordVersion — both removed
// from TUpdateUserDto when the senior-architecture refactor moved
// version into the If-Match header per RFC 7232) and the header
// plumbing so individual test cases stay focused on the assertion.
func makeUpdateReq(id uuid.UUID, ifMatch, body string) *http.Request {
	req := httptest.NewRequest(http.MethodPut, fmt.Sprintf("/users/%s", id), bytes.NewBufferString(body))
	req.Header.Set("Content-Type", "application/json")
	if ifMatch != "" {
		req.Header.Set("If-Match", ifMatch)
	}
	return req
}

// TestUpdateUser_OK_200 — happy path. If-Match matches; the service
// returns the updated user; the response carries the bumped
// RecordVersion in the ETag header for the next round-trip.
func TestUpdateUser_OK_200(t *testing.T) {
	svc := &mocks.MockUserService{}
	id := uuid.New()
	updated := validUserModel(id)
	updated.RecordVersion = 8 // bumped from 7
	svc.On("Update", mock.Anything, id, 7, mock.Anything).Return(updated, nil)

	c := controllers.NewUserControllerInstance(svc, noopValidator{})
	rec := httptest.NewRecorder()
	mountController(c).ServeHTTP(rec, makeUpdateReq(id, `"7"`, `{"firstName":"Changed"}`))

	assert.Equal(t, http.StatusOK, rec.Code)
	assert.Equal(t, `"8"`, rec.Header().Get("ETag"),
		"response ETag must advance to the new RecordVersion so the client can chain updates")
}

// TestUpdateUser_MissingIfMatch_428 — RFC 6585: 428 Precondition
// Required when the If-Match header is missing. Protects against the
// lost-update problem.
func TestUpdateUser_MissingIfMatch_428(t *testing.T) {
	svc := &mocks.MockUserService{}
	id := uuid.New()
	c := controllers.NewUserControllerInstance(svc, noopValidator{})
	rec := httptest.NewRecorder()
	mountController(c).ServeHTTP(rec, makeUpdateReq(id, "", `{"firstName":"X"}`))

	assert.Equal(t, http.StatusPreconditionRequired, rec.Code)
	svc.AssertNotCalled(t, "Update")
}

// TestUpdateUser_VersionConflict_412 — RFC 7232: 412 Precondition
// Failed when If-Match doesn't match the persisted RecordVersion.
// (Was 409 in the pre-If-Match design — switched to 412 because the
// HTTP-native condition is "precondition failed", not "conflict".)
func TestUpdateUser_VersionConflict_412(t *testing.T) {
	svc := &mocks.MockUserService{}
	id := uuid.New()
	svc.On("Update", mock.Anything, id, 7, mock.Anything).
		Return(nil, services.ErrUserVersionConflict)

	c := controllers.NewUserControllerInstance(svc, noopValidator{})
	rec := httptest.NewRecorder()
	mountController(c).ServeHTTP(rec, makeUpdateReq(id, `"7"`, `{"firstName":"Changed"}`))

	assert.Equal(t, http.StatusPreconditionFailed, rec.Code)
}

// TestUpdateUser_BadIfMatch_400 — non-numeric If-Match is a client
// error; we surface 400 (not 412) because the value couldn't be
// compared at all.
func TestUpdateUser_BadIfMatch_400(t *testing.T) {
	svc := &mocks.MockUserService{}

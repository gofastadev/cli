// ── ArchiveUser ───────────────────────────────────────────────────────

// TestArchiveUser_OK_200 — success returns 200 with the soft-deleted
// record (Stripe pattern), NOT 204 No Content. The body carries
// `deletedAt` and `isActive: false` so the client can immediately
// reflect the change in the UI without re-fetching.
func TestArchiveUser_OK_200(t *testing.T) {
	svc := &mocks.MockUserService{}
	id := uuid.New()
	deleted := validUserModel(id)
	deleted.DeletedAt = gorm.DeletedAt{Time: time.Now(), Valid: true}
	deleted.IsActive = false
	svc.On("Archive", mock.Anything, id).Return(deleted, nil)

	c := controllers.NewUserControllerInstance(svc, noopValidator{})
	req := httptest.NewRequest(http.MethodDelete, fmt.Sprintf("/users/%s", id), nil)
	rec := httptest.NewRecorder()
	mountController(c).ServeHTTP(rec, req)

	assert.Equal(t, http.StatusOK, rec.Code)
	assert.NotEmpty(t, rec.Body.String(), "200 must carry the deleted record")
	assert.Contains(t, rec.Body.String(), `"deletedAt"`)
}

// TestArchiveUser_NotFound_404 — idempotency contract: a second
// archive of the same id (or an unknown id) returns 404, NOT a
// spurious 409. Matches GitHub / Kubernetes DELETE semantics.
func TestArchiveUser_NotFound_404(t *testing.T) {
	svc := &mocks.MockUserService{}
	id := uuid.New()
	svc.On("Archive", mock.Anything, id).Return(nil, services.ErrUserNotFound)

	c := controllers.NewUserControllerInstance(svc, noopValidator{})
	req := httptest.NewRequest(http.MethodDelete, fmt.Sprintf("/users/%s", id), nil)
	rec := httptest.NewRecorder()
	mountController(c).ServeHTTP(rec, req)

	assert.Equal(t, http.StatusNotFound, rec.Code)
}

// TestArchiveUser_NotDeletable_409 — policy refusal: the row exists

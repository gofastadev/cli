//go:build wireinject

package di

import (
	"github.com/google/wire"
	"{{.ModulePath}}/app/di/providers"
)

// InitializeServiceContainer builds the full dependency graph at compile time.
func InitializeServiceContainer() (*ServiceContainer, error) {
	wire.Build(
		providers.CoreSet,
		providers.UserSet,
		// gofasta:scaffold:wire-providers — `gofasta g scaffold` inserts new providers.<Name>Set entries above this line. Don't remove the marker; the CLI relies on it to find the insertion point.
{{- if .GraphQL}}
		providers.GraphQLSet,
{{- end}}
		wire.Struct(new(ServiceContainer), "*"),
	)
	return nil, nil
}

// --- Config extractors ---

// ProvideDB wraps config.SetupDB with the devtools GORM plugin so SQL
// queries are captured into the dev dashboard's ring buffer when the
// binary is built with the `devtools` tag. In production builds the
// plugin is a no-op (see app/devtools/devtools_stub.go).
//
// Degraded-mode behavior: a cheap TCP probe runs FIRST so we can skip
// config.SetupDB entirely when the DB is unreachable. SetupDB calls
// gorm.Open, which logs `[error] failed to initialize database` from
// inside GORM before returning the error, and then SetupDB itself
// slog.Error's and panics. Probing first means none of that noise
// appears in degraded mode — just the WARN below explaining what
// happened. When `gofasta dev` is in front of this, the developer
// has already seen the preflight menu and picked "Run app without
// db"; the in-app logs should match that choice, not contradict it
// with red ERROR lines.
//
// Recovery via panic catch is still in place as a belt-and-braces
// layer for races (DB went down between the probe and SetupDB) and
// for non-TCP drivers (SQLite file-mode, etc.).
func ProvideDB(cfg *config.DatabaseConfig) *gorm.DB {
	if !databaseReachable(cfg) {
		slog.Warn(
			"database unreachable — starting in DEGRADED mode; endpoints touching the DB will return 5xx until the connection comes back",
			"driver", cfg.Driver, "host", cfg.Host, "port", cfg.Port,
		)
		return buildDegradedDB(cfg)
	}
	db, err := tryConnectDB(cfg)
	if err == nil {
		if pluginErr := db.Use(devtools.GormPlugin()); pluginErr != nil {
			slog.Warn("failed to install devtools GORM plugin", "error", pluginErr)
		}
		return db
	}
	slog.Warn(
		"database connect failed after reachability probe passed — starting in DEGRADED mode",
		"driver", cfg.Driver, "host", cfg.Host, "port", cfg.Port, "error", err,
	)
	return buildDegradedDB(cfg)
}

// databaseReachable opens and closes a 2-second TCP connection to
// cfg.Host:cfg.Port to confirm the DB is accepting connections. For
// file-backed drivers (sqlite, sqlite3) the answer is always yes:
// they have no network endpoint to probe. Any other connect failure
// (DNS, refused, timeout) returns false so the caller skips SetupDB.
//
// 2 seconds is the same budget `gofasta dev`'s preflight probe uses,
// keeping the in-app behavior consistent with what the developer saw
// at the menu.
func databaseReachable(cfg *config.DatabaseConfig) bool {
	if cfg.Driver == "sqlite" || cfg.Driver == "sqlite3" {
		return true
	}
	if cfg.Host == "" || cfg.Port == "" {
		return false
	}
	addr := net.JoinHostPort(cfg.Host, cfg.Port)
	conn, err := net.DialTimeout("tcp", addr, 2*time.Second)
	if err != nil {
		return false
	}
	_ = conn.Close()
	return true
}

// tryConnectDB calls config.SetupDB and recovers from its panic. On
// success returns (db, nil); on connection failure returns (nil, err)
// with the panic value wrapped in an error.
func tryConnectDB(cfg *config.DatabaseConfig) (db *gorm.DB, err error) {
	defer func() {
		if r := recover(); r != nil {
			db = nil
			err = fmt.Errorf("%v", r)
		}
	}()
	db = config.SetupDB(cfg)
	return db, nil
}

// buildDegradedDB returns an in-memory SQLite *gorm.DB to stand in
// for the unreachable real database. The choice of SQLite is
// deliberate: it's network-free, always works, and is the only
// scaffold-supported driver guaranteed to succeed without external
// state. Repositories injected with this stub will get "no such
// table: X" errors when they try to query (because the project's
// migrations haven't run against it), and that error propagates as
// 5xx through pkg/httputil.Handle().
//
// The app boots, non-DB endpoints serve normally, DB-touching
// endpoints fail loudly with a clear error. Exactly what the
// preflight's "Run app without db" menu option promises.
func buildDegradedDB(cfg *config.DatabaseConfig) *gorm.DB {
	db, err := gorm.Open(sqlite.Open(":memory:"), &gorm.Config{})
	if err != nil {
		// Last-resort fallback: a literally-empty gorm.DB. Repositories
		// that call methods on it will nil-panic on internal fields,
		// which surfaces clearly in logs and signals that the degraded-
		// mode bootstrap itself failed. Should never happen — SQLite
		// in-memory is essentially infallible — but guarded for safety.
		slog.Error("degraded-DB bootstrap failed; returning empty *gorm.DB",
			"driver", cfg.Driver, "error", err)
		return &gorm.DB{Config: &gorm.Config{}}
	}
	return db
}

// ProvideCacheService wraps cache.NewCacheService with the devtools
// cache decorator so every Get/Set/Delete/Flush/Ping op is teed into
// the dev-dashboard cache-ops ring. Stub builds return the inner
// cache unchanged, so the call costs one indirection per op in dev
// and zero in production.
func ProvideCacheService(cfg *config.CacheConfig, log *slog.Logger) (cache.CacheService, error) {
	inner, err := cache.NewCacheService(cfg, log)
	if err != nil {
		return nil, err
	}
	return devtools.WrapCache(inner), nil
}

// ProvideLogger wraps logger.NewLogger with the devtools slog
// decorator. Every log record continues to flow to stdout through the
// framework's handler (text or JSON, level from config) AND is teed
// into the dev-dashboard's log ring keyed by trace ID. In production
// builds (no `devtools` build tag) the wrapper is identity, so the
// cost is zero.
func ProvideLogger(cfg *config.LogConfig) *slog.Logger {
	base := logger.NewLogger(cfg)
	wrapped := slog.New(devtools.WrapLogger(base.Handler()))
	slog.SetDefault(wrapped)
	return wrapped
}

// The functions below pluck a typed sub-config off the loaded AppConfig.
// Wire needs each as a separate provider so packages that only depend on
// (say) DatabaseConfig don't transitively pull AppConfig into their
// build graph.

// ProvideDBConfig exposes the Database section of AppConfig as a Wire provider.
func ProvideDBConfig(cfg *config.AppConfig) *config.DatabaseConfig { return &cfg.Database }

// ProvideLogConfig exposes the Log section of AppConfig as a Wire provider.
func ProvideLogConfig(cfg *config.AppConfig) *config.LogConfig { return &cfg.Log }

// ProvideEmailConfig exposes the Email section of AppConfig as a Wire provider.
func ProvideEmailConfig(cfg *config.AppConfig) *config.EmailConfig { return &cfg.Email }

// ProvideSlackConfig exposes the Slack section of AppConfig as a Wire provider.
func ProvideSlackConfig(cfg *config.AppConfig) *config.SlackConfig { return &cfg.Slack }

// ProvideWhatsAppConfig exposes the WhatsApp section of AppConfig as a Wire provider.
func ProvideWhatsAppConfig(cfg *config.AppConfig) *config.WhatsAppConfig { return &cfg.WhatsApp }

// ProvideAuthConfig exposes the Auth section of AppConfig as a Wire provider.
func ProvideAuthConfig(cfg *config.AppConfig) *config.AuthConfig { return &cfg.Auth }

// ProvideCacheConfig exposes the Cache section of AppConfig as a Wire provider.
func ProvideCacheConfig(cfg *config.AppConfig) *config.CacheConfig { return &cfg.Cache }

// ProvideStorageConfig exposes the Storage section of AppConfig as a Wire provider.

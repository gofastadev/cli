// LoadConfig reads configuration for this project.
//
// It calls config.LoadConfigWithPrefix with the project's uppercased name
// as the env var prefix, so variables like {{.ProjectNameUpper}}_DATABASE_HOST
// are honored. Using the project's own name as the prefix means the .env
// file, docker-compose, and CI configs all read variables named after the
// project itself — no toolkit branding leaks into your infrastructure files. A developer who later replaces pkg/config with a
// different loader can reuse the same env var names without renaming
// anything in their deployment configs.
func LoadConfig() (*config.AppConfig, error) {
	return config.LoadConfigWithPrefix("{{.ProjectNameUpper}}_")
}

// CoreSet provides all core infrastructure.
var CoreSet = wire.NewSet(
	// Config
	LoadConfig,
	ProvideDBConfig,
	ProvideLogConfig,
	ProvideEmailConfig,
	ProvideSlackConfig,
	ProvideWhatsAppConfig,
	ProvideAuthConfig,
	ProvideCacheConfig,
	ProvideStorageConfig,
	ProvideQueueConfig,
	// Infrastructure
	ProvideDB,
	ProvideLogger,
	validators.NewAppValidator,
	ProvideTemplateRenderer,
	mailer.NewEmailSender,
	slack.NewSlackSender,
	whatsapp.NewSender,
	auth.NewJWTService,
	auth.NewRBACService,
	ProvideCacheService,
	storage.NewStorageService,
	queue.NewQueueService,
	// Newly wired
	ProvideWebSocketHub,
	ProvideNotifier,
	ProvideI18nService,
	ProvideEncrypter,
	ProvideSessionStore,
)

// --- Config extractors ---

// ProvideDB wraps config.SetupDB with the devtools GORM plugin so SQL
// queries are captured into the dev dashboard's ring buffer when the
// binary is built with the `devtools` tag. In production builds the
// plugin is a no-op (see app/devtools/devtools_stub.go). Safe to call
// unconditionally.
func ProvideDB(cfg *config.DatabaseConfig) *gorm.DB {
	db := config.SetupDB(cfg)
	if err := db.Use(devtools.GormPlugin()); err != nil {
		slog.Warn("failed to install devtools GORM plugin", "error", err)
	}
	return db
}

// ProvideCacheService wraps cache.NewCacheService with the devtools
// cache decorator so every Get/Set/Delete/Flush/Ping op is teed into
// the dev-dashboard cache-ops ring. Stub builds return the inner
// cache unchanged, so the call costs one indirection per op in dev
// and zero in production.
func ProvideCacheService(cfg *config.CacheConfig, log *slog.Logger) (cache.CacheService, error) {
	inner, err := cache.NewCacheService(cfg, log)
	if err != nil {
		return nil, err
	}
	return devtools.WrapCache(inner), nil
}

// ProvideLogger wraps logger.NewLogger with the devtools slog
// decorator. Every log record continues to flow to stdout through the
// framework's handler (text or JSON, level from config) AND is teed
// into the dev-dashboard's log ring keyed by trace ID. In production
// builds (no `devtools` build tag) the wrapper is identity, so the
// cost is zero.
func ProvideLogger(cfg *config.LogConfig) *slog.Logger {
	base := logger.NewLogger(cfg)
	wrapped := slog.New(devtools.WrapLogger(base.Handler()))
	slog.SetDefault(wrapped)
	return wrapped
}

// The functions below pluck a typed sub-config off the loaded AppConfig.
// Wire needs each as a separate provider so packages that only depend on
// (say) DatabaseConfig don't transitively pull AppConfig into their
// build graph.

// ProvideDBConfig exposes the Database section of AppConfig as a Wire provider.
func ProvideDBConfig(cfg *config.AppConfig) *config.DatabaseConfig { return &cfg.Database }

// ProvideLogConfig exposes the Log section of AppConfig as a Wire provider.
func ProvideLogConfig(cfg *config.AppConfig) *config.LogConfig { return &cfg.Log }

// ProvideEmailConfig exposes the Email section of AppConfig as a Wire provider.
func ProvideEmailConfig(cfg *config.AppConfig) *config.EmailConfig { return &cfg.Email }

// ProvideSlackConfig exposes the Slack section of AppConfig as a Wire provider.
func ProvideSlackConfig(cfg *config.AppConfig) *config.SlackConfig { return &cfg.Slack }

// ProvideWhatsAppConfig exposes the WhatsApp section of AppConfig as a Wire provider.
func ProvideWhatsAppConfig(cfg *config.AppConfig) *config.WhatsAppConfig { return &cfg.WhatsApp }

// ProvideAuthConfig exposes the Auth section of AppConfig as a Wire provider.
func ProvideAuthConfig(cfg *config.AppConfig) *config.AuthConfig { return &cfg.Auth }

// ProvideCacheConfig exposes the Cache section of AppConfig as a Wire provider.
func ProvideCacheConfig(cfg *config.AppConfig) *config.CacheConfig { return &cfg.Cache }

// ProvideStorageConfig exposes the Storage section of AppConfig as a Wire provider.
func ProvideStorageConfig(cfg *config.AppConfig) *config.StorageConfig { return &cfg.Storage }

// ProvideQueueConfig exposes the Queue section of AppConfig as a Wire provider.
func ProvideQueueConfig(cfg *config.AppConfig) *config.QueueConfig { return &cfg.Queue }

// --- Complex providers ---

// ProvideTemplateRenderer constructs the HTML email template renderer
// rooted at templates/emails and stamps every email with the configured
// From-name as the default sender.
func ProvideTemplateRenderer(cfg *config.AppConfig) *mailer.TemplateRenderer {
	return mailer.NewTemplateRenderer("templates/emails", cfg.Email.FromName)
}

// ProvideWebSocketHub constructs the framework's WebSocket hub used for
// real-time fan-out (rooms, broadcasts, per-connection state).
func ProvideWebSocketHub(log *slog.Logger) *websocket.Hub {
	return websocket.NewHub(log)
}

// ProvideNotifier wires a multi-channel notifier with email + database
// channels enabled by default. Add channels (Slack, SMS, etc.) here as
// the project grows.
func ProvideNotifier(log *slog.Logger, emailSender mailer.EmailSender, db *gorm.DB) *notify.Notifier {
	return notify.NewNotifier(log,
		notify.NewEmailChannel(emailSender),
		notify.NewDatabaseChannel(db),
	)
}

// ProvideI18nService constructs the i18n service backed by the locales
// directory + default language declared in config.
func ProvideI18nService(cfg *config.AppConfig) *i18n.I18nService {
	return i18n.NewI18nService(cfg.I18n.LocalesDir, cfg.I18n.DefaultLanguage)
}

// ProvideEncrypter constructs the AES-256-GCM encrypter used for
// at-rest field encryption. Returns nil if no key is configured or if
// the key fails to parse — callers should treat a nil encrypter as
// "encryption disabled" rather than panic.
func ProvideEncrypter(cfg *config.AppConfig) *encryption.Encrypter {
	if cfg.Encryption.Key == "" {
		return nil
	}
	enc, err := encryption.NewEncrypter(cfg.Encryption.Key)
	if err != nil {
		return nil
	}
	return enc
}

// ProvideSessionStore constructs the session store named by config —
// filesystem-backed when sessions need to survive a process restart,
// cookie-backed (the default) when statelessness is preferred.
func ProvideSessionStore(cfg *config.AppConfig) *session.Store {
	sc := cfg.Session
	if sc.Driver == "filesystem" {
		return session.NewFilesystemStore(sc.FilesystemPath, sc.Secret, sc.SessionName)
	}
	return session.NewCookieStore(sc.Secret, sc.SessionName)
}

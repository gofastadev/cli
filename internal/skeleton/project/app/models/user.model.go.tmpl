package models

import "github.com/gofastadev/gofasta/pkg/models"

// User is the persistent record for a registered account. It embeds the
// framework's BaseModelImpl, which provides the ID, CreatedAt, UpdatedAt,
// DeletedAt, RecordVersion, IsActive, and IsDeletable columns so this
// type only declares what's specific to a user.
type User struct {
	models.BaseModelImpl
	FirstName   string `gorm:"not null"`
	OtherNames  string `gorm:"not null"`
	Email       string `gorm:"not null"`
	PhoneNumber string `gorm:"not null"`
	Password    string `gorm:"not null"`
}

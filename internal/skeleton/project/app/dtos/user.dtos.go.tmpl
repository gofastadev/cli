// User is the wire shape returned to clients. It's the projection of
// the persistent User model with sensitive fields (Password) excluded.
type User struct {
	ID            uuid.UUID  `json:"id"`
	RecordVersion int        `json:"recordVersion"`
	CreatedAt     time.Time  `json:"createdAt"`
	UpdatedAt     time.Time  `json:"updatedAt"`
	FirstName     string     `json:"firstName"`
	OtherNames    string     `json:"otherNames"`
	Email         string     `json:"email"`
	PhoneNumber   string     `json:"phoneNumber"`
	IsActive      bool       `json:"isActive"`
	IsDeletable   bool       `json:"isDeletable"`
	DeletedAt     *time.Time `json:"deletedAt,omitempty"`
}

// UserFromModel maps a persisted User onto its public-facing DTO.
// Soft-delete handling: the DTO emits `deletedAt` only when the row
// was actually soft-deleted (gorm.DeletedAt.Valid == true). A non-nil
// pointer to a zero time would render as "0001-01-01T00:00:00Z" in
// JSON instead of being omitted via the omitempty tag.
func UserFromModel(m *models.User) *User {
	out := &User{
		ID:            m.ID,
		RecordVersion: m.RecordVersion,
		CreatedAt:     m.CreatedAt,
		UpdatedAt:     m.UpdatedAt,
		FirstName:     m.FirstName,
		OtherNames:    m.OtherNames,
		Email:         m.Email,
		PhoneNumber:   m.PhoneNumber,
		IsActive:      m.IsActive,
		IsDeletable:   m.IsDeletable,
	}
	if m.DeletedAt.Valid {
		t := m.DeletedAt.Time
		out.DeletedAt = &t
	}
	return out
}

// TUserResponseDto is the success-shape envelope for endpoints that
// return a single user. Validation failures and other errors flow via
// HTTP status codes (4xx) carrying the framework's apperrors envelope
// — there is intentionally no `Errors` field here.
type TUserResponseDto struct {
	Data *User `json:"data,omitempty"`
}

// TUsersResponseDto is the success-shape envelope for list endpoints,
// pairing the page of records with pagination metadata.
type TUsersResponseDto struct {
	Data       []*User               `json:"data"`
	Pagination *TPaginationObjectDto `json:"pagination"`
}

// UsersFromModels maps the slice form for list responses.
func UsersFromModels(ms []*models.User) []*User {
	out := make([]*User, 0, len(ms))
	for _, m := range ms {
		out = append(out, UserFromModel(m))
	}
	return out
}

// TCreateUserDto is the input for the create-user endpoint. Every
// field carries a validate tag so the controller can run the
// AppValidator and reject malformed input with HTTP 422 before
// reaching the service layer.
type TCreateUserDto struct {
	FirstName   string `json:"firstName" validate:"required,min=1,max=50"`
	OtherNames  string `json:"otherNames" validate:"required,min=1,max=150"`
	Email       string `json:"email" validate:"required,email,is_record_exist_by_email_for_conflict=users"`
	PhoneNumber string `json:"phoneNumber" validate:"required,is_valid_phone_number,is_record_exist_by_phone_number_for_conflict=users"`
}

// ToCreateInput translates the wire DTO into the typed domain input
// the service expects. Keeps the service free of any wire-format knowledge.
func (d TCreateUserDto) ToCreateInput() services.CreateUserInput {
	return services.CreateUserInput{
		FirstName:   d.FirstName,
		OtherNames:  d.OtherNames,
		Email:       d.Email,
		PhoneNumber: d.PhoneNumber,
	}
}

// TUpdateUserDto is the input for partial updates. Optional fields
// are pointers so the controller can distinguish "absent from request"
// (nil → don't touch) from "present-but-empty" (non-nil → update to
// the empty value).
//
// `ID` and `RecordVersion` are intentionally NOT here:
//   - The ID comes from the URL path (`PUT /users/{id}`) — putting
//     the same value in two places of one request is awkward and
//     opens a class of mismatch bugs ("body.id == url.id?").
//   - RecordVersion is a precondition, not data, so it travels in the
//     `If-Match` header per RFC 7232. The controller reads the header,
//     parses it, and passes it to the service alongside the patch.
//     This is the industry standard (Azure, GCP, Kubernetes, GitHub) —
//     QuickBooks' SyncToken-in-body pattern is the outlier.
type TUpdateUserDto struct {
	FirstName   *string `json:"firstName,omitempty" validate:"omitempty,min=1,max=50"`
	OtherNames  *string `json:"otherNames,omitempty" validate:"omitempty,min=1,max=150"`
	Email       *string `json:"email,omitempty" validate:"omitempty,email,is_record_exist_by_email_for_conflict=users"`
	PhoneNumber *string `json:"phoneNumber,omitempty" validate:"omitempty,is_record_exist_by_phone_number_for_conflict=users"`
	IsActive    *bool   `json:"isActive,omitempty"`
	IsDeletable *bool   `json:"isDeletable,omitempty"`
}

// ToPatch translates the wire DTO into the typed domain patch the
// service expects.
func (d TUpdateUserDto) ToPatch() services.UpdateUserPatch {
	return services.UpdateUserPatch{
		FirstName:   d.FirstName,
		OtherNames:  d.OtherNames,
		Email:       d.Email,
		PhoneNumber: d.PhoneNumber,
		IsActive:    d.IsActive,
		IsDeletable: d.IsDeletable,
	}
}

// TUpdateUserGraphQLInput is the GraphQL-only counterpart to
// TUpdateUserDto. GraphQL has no HTTP headers and no URL paths, so
// the id + recordVersion that REST carries in `PUT /users/{id}` +
// `If-Match: "<v>"` live inside the input object instead. Two distinct
// types (rather than reusing TUpdateUserDto) keep the REST shape
// strict — the JSON body for a REST PUT must not include id or
// recordVersion, and a shared type with optional fields would lose
// that guarantee.
//
// gqlgen's `autobind: app/dtos` config picks this type up automatically
// because its name matches the schema's input `TUpdateUserGraphQLInput`
// — no models block in gqlgen.yml needed.
type TUpdateUserGraphQLInput struct {
	ID            uuid.UUID `json:"id" validate:"required,uuid4_valid,does_record_exist_by_id_for_verification=users"`
	RecordVersion int       `json:"recordVersion" validate:"required,min=1"`
	FirstName     *string   `json:"firstName,omitempty" validate:"omitempty,min=1,max=50"`
	OtherNames    *string   `json:"otherNames,omitempty" validate:"omitempty,min=1,max=150"`
	Email         *string   `json:"email,omitempty" validate:"omitempty,email,is_record_exist_by_email_for_conflict=users"`
	PhoneNumber   *string   `json:"phoneNumber,omitempty" validate:"omitempty,is_record_exist_by_phone_number_for_conflict=users"`
	IsActive      *bool     `json:"IsActive,omitempty"`
	IsDeletable   *bool     `json:"IsDeletable,omitempty"`
}

// ToPatch translates the GraphQL input into the typed domain patch the
// service consumes. Symmetric with TUpdateUserDto.ToPatch so the two
// resolver paths converge on services.UpdateUserPatch.
func (d TUpdateUserGraphQLInput) ToPatch() services.UpdateUserPatch {
	return services.UpdateUserPatch{
		FirstName:   d.FirstName,
		OtherNames:  d.OtherNames,
		Email:       d.Email,
		PhoneNumber: d.PhoneNumber,
		IsActive:    d.IsActive,
		IsDeletable: d.IsDeletable,
	}
}

// TArchiveUserDto is the input for the soft-delete endpoint. The
// is_record_deletable validator gates rows whose IsDeletable flag is
// false at the boundary; the service ALSO enforces this in the SQL
// WHERE clause as a defense-in-depth measure.
type TArchiveUserDto struct {
	UserID uuid.UUID `json:"userId" validate:"uuid4_valid,does_record_exist_by_id_for_verification=users,is_record_deletable=users"`
}

// TFindUserByIDDto is the input for the get-user-by-id endpoint.
type TFindUserByIDDto struct {
	UserID uuid.UUID `json:"userId" validate:"uuid4_valid,does_record_exist_by_id_for_verification=users"`
}

// TUserFiltersQueryParamsDto is the flat query-string shape decoded
// from REST list requests. Every field is optional with defaults
// applied at the boundary (page=1, limit=10, sort=createdAt DESC).
type TUserFiltersQueryParamsDto struct {
	FirstName       *string          `json:"firstName,omitempty" schema:"firstName"`
	OtherNames      *string          `json:"otherNames,omitempty" schema:"otherNames"`
	Email           *string          `json:"email,omitempty" schema:"email"`
	PhoneNumber     *string          `json:"phoneNumber,omitempty" schema:"phoneNumber"`
	Limit           *int             `json:"limit,omitempty" schema:"limit" validate:"omitempty,gte=1"`
	Page            *int             `json:"page,omitempty" schema:"page" validate:"omitempty,gte=1"`
	SortByField     *string          `json:"sortByField,omitempty" schema:"sortByField"`
	SortOrientation *SortOrientation `json:"sortOrientation,omitempty" schema:"sortOrientation" validate:"omitempty"`
}

// ToFilter translates the wire query DTO into the typed domain filter
// the service expects, applying defaults (page=1, limit=10,
// SortField=created_at, SortDesc=true).
func (q TUserFiltersQueryParamsDto) ToFilter() services.ListUsersFilter {
	f := services.ListUsersFilter{
		FirstName:   q.FirstName,
		OtherNames:  q.OtherNames,
		Email:       q.Email,
		PhoneNumber: q.PhoneNumber,
		Page:        1,
		Limit:       10,
		SortField:   "created_at",
		SortDesc:    true,
	}
	if q.Page != nil && *q.Page > 0 {
		f.Page = *q.Page
	}
	if q.Limit != nil && *q.Limit > 0 {
		f.Limit = *q.Limit
	}
	if q.SortByField != nil && *q.SortByField != "" {
		f.SortField = *q.SortByField
	}
	if q.SortOrientation != nil && q.SortOrientation.IsValid() {
		f.SortDesc = (*q.SortOrientation == SortOrientationDesc)
	}
	return f
}

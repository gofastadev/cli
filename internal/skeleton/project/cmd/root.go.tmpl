package cmd

import (
	"fmt"
	"os"

	"github.com/spf13/cobra"
)

var rootCmd = &cobra.Command{
	Use:   "{{.ProjectNameLower}}",
	Short: "{{.ProjectName}} - A Go web application built with Gofasta",
	Long:  "{{.ProjectName}} is a web application built with the Gofasta Go backend toolkit.",
}

// Execute runs the root command.
func Execute() {
	if err := rootCmd.Execute(); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}

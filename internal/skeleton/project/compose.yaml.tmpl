# {{.ProjectName}} Development Environment
# Usage: docker compose up
# That's it. No .env needed for basic startup.

services:
  app:
    build:
      context: .
      dockerfile: deployments/docker/dev.dockerfile
    container_name: {{.ProjectNameLower}}_app
    ports:
      - "${PORT:-8080}:${PORT:-8080}"
    volumes:
      - .:/{{.ProjectNameLower}}
      - go_modules:/go/pkg/mod
      - go_build_cache:/root/.cache/go-build
    environment:
      - PORT=${PORT:-8080}
      # Listen on all interfaces inside the container so the host can reach
      # the published port. The framework's default Server.Host is the
      # loopback 127.0.0.1 (which sidesteps macOS's firewall prompt during
      # host-side Air rebuilds), so the dockerized dev container has to
      # opt out of that default explicitly.
      - {{.ProjectNameUpper}}_SERVER_HOST=0.0.0.0
      - {{.ProjectNameUpper}}_DATABASE_DRIVER=${{"{"}}{{.ProjectNameUpper}}_DATABASE_DRIVER:-{{.DBDriver}}}
{{- if eq .DBDriver "sqlite" }}
      - {{.ProjectNameUpper}}_DATABASE_NAME=${{"{"}}{{.ProjectNameUpper}}_DATABASE_NAME:-{{.ProjectNameLower}}.db}
{{- else if eq .DBDriver "mysql" }}
      - {{.ProjectNameUpper}}_DATABASE_HOST=db
      - {{.ProjectNameUpper}}_DATABASE_PORT=3306
      - {{.ProjectNameUpper}}_DATABASE_USER=${{"{"}}{{.ProjectNameUpper}}_DATABASE_USER:-{{.ProjectNameLower}}}
      - {{.ProjectNameUpper}}_DATABASE_PASSWORD=${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-{{.ProjectNameLower}}}
      - {{.ProjectNameUpper}}_DATABASE_NAME=${{"{"}}{{.ProjectNameUpper}}_DATABASE_NAME:-{{.ProjectNameLower}}_dev}
{{- else if eq .DBDriver "sqlserver" }}
      - {{.ProjectNameUpper}}_DATABASE_HOST=db
      - {{.ProjectNameUpper}}_DATABASE_PORT=1433
      - {{.ProjectNameUpper}}_DATABASE_USER=sa
      - {{.ProjectNameUpper}}_DATABASE_PASSWORD=${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-YourStrong@Passw0rd}
      - {{.ProjectNameUpper}}_DATABASE_NAME=${{"{"}}{{.ProjectNameUpper}}_DATABASE_NAME:-{{.ProjectNameLower}}_dev}
{{- else if eq .DBDriver "clickhouse" }}
      - {{.ProjectNameUpper}}_DATABASE_HOST=db
      - {{.ProjectNameUpper}}_DATABASE_PORT=9000
      - {{.ProjectNameUpper}}_DATABASE_USER=default
      - {{.ProjectNameUpper}}_DATABASE_PASSWORD=${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-}
      - {{.ProjectNameUpper}}_DATABASE_NAME=${{"{"}}{{.ProjectNameUpper}}_DATABASE_NAME:-{{.ProjectNameLower}}_dev}
{{- else }}
      - {{.ProjectNameUpper}}_DATABASE_HOST=db
      - {{.ProjectNameUpper}}_DATABASE_PORT=5432
      - {{.ProjectNameUpper}}_DATABASE_USER=${{"{"}}{{.ProjectNameUpper}}_DATABASE_USER:-{{.ProjectNameLower}}}
      - {{.ProjectNameUpper}}_DATABASE_PASSWORD=${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-{{.ProjectNameLower}}}
      - {{.ProjectNameUpper}}_DATABASE_NAME=${{"{"}}{{.ProjectNameUpper}}_DATABASE_NAME:-{{.ProjectNameLower}}_dev}
      - {{.ProjectNameUpper}}_DATABASE_SSLMODE=disable
{{- end }}
      - {{.ProjectNameUpper}}_LOG_LEVEL=${{"{"}}{{.ProjectNameUpper}}_LOG_LEVEL:-debug}
      - {{.ProjectNameUpper}}_LOG_FORMAT=${{"{"}}{{.ProjectNameUpper}}_LOG_FORMAT:-text}
{{- if ne .DBDriver "sqlite" }}
    depends_on:
      db:
        condition: service_healthy
{{- end }}
    restart: unless-stopped

{{- if eq .DBDriver "postgres" }}

  db:
    image: postgres:18-alpine
    container_name: {{.ProjectNameLower}}_db
    ports:
      # One source of truth for "the database port":
      # {{.ProjectNameUpper}}_DATABASE_PORT. It governs both the host-
      # running app's connection target AND this host-side port mapping.
      # The `:5432` on the right is the postgres image's hardcoded
      # listen port (not user-configurable).
      - "${{"{"}}{{.ProjectNameUpper}}_DATABASE_PORT:-5433}:5432"
    environment:
      POSTGRES_USER: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_USER:-{{.ProjectNameLower}}}
      POSTGRES_PASSWORD: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-{{.ProjectNameLower}}}
      POSTGRES_DB: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_NAME:-{{.ProjectNameLower}}_dev}
    volumes:
      - db_data:/var/lib/postgresql
    healthcheck:
      # pg_isready must target the actual database name — without -d it tries
      # to connect to a database named after the user, which is wrong whenever
      # POSTGRES_DB differs from POSTGRES_USER and fills the log with
      # "database <user> does not exist" FATALs until the retry budget is used
      # up (or forever, if the container restarts).
      test: ["CMD-SHELL", "pg_isready -U ${{"{"}}{{.ProjectNameUpper}}_DATABASE_USER:-{{.ProjectNameLower}}} -d ${{"{"}}{{.ProjectNameUpper}}_DATABASE_NAME:-{{.ProjectNameLower}}_dev}"]
      interval: 2s
      timeout: 5s
      retries: 10
    restart: unless-stopped
{{- else if eq .DBDriver "mysql" }}

  db:
    image: mysql:8.4
    container_name: {{.ProjectNameLower}}_db
    # log_bin_trust_function_creators=ON lets non-SUPER schema users
    # CREATE TRIGGER on their own database — required because the
    # scaffold's per-resource migrations install BEFORE UPDATE +
    # BEFORE DELETE triggers via the application's DB user, which
    # only holds schema-level privileges.
    command: ["--log_bin_trust_function_creators=ON"]
    ports:
      - "${{"{"}}{{.ProjectNameUpper}}_DATABASE_PORT:-3307}:3306"
    environment:
      MYSQL_ROOT_PASSWORD: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-{{.ProjectNameLower}}}
      MYSQL_USER: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_USER:-{{.ProjectNameLower}}}
      MYSQL_PASSWORD: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-{{.ProjectNameLower}}}
      MYSQL_DATABASE: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_NAME:-{{.ProjectNameLower}}_dev}
    volumes:
      - db_data:/var/lib/mysql
    healthcheck:
      test: ["CMD-SHELL", "mysqladmin ping -h 127.0.0.1 -u ${{"{"}}{{.ProjectNameUpper}}_DATABASE_USER:-{{.ProjectNameLower}}} -p${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-{{.ProjectNameLower}}} | grep -q 'mysqld is alive'"]
      interval: 2s
      timeout: 5s
      retries: 30
    restart: unless-stopped
{{- else if eq .DBDriver "sqlserver" }}

  db:
    image: mcr.microsoft.com/mssql/server:2022-latest
    container_name: {{.ProjectNameLower}}_db
    user: root
    ports:
      - "${{"{"}}{{.ProjectNameUpper}}_DATABASE_PORT:-1434}:1433"
    environment:
      ACCEPT_EULA: "Y"
      MSSQL_SA_PASSWORD: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-YourStrong@Passw0rd}
      MSSQL_PID: Developer
    volumes:
      - db_data:/var/opt/mssql
    healthcheck:
      test: ["CMD-SHELL", "/opt/mssql-tools18/bin/sqlcmd -S localhost -U sa -P ${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-YourStrong@Passw0rd} -No -Q 'SELECT 1' || exit 1"]
      interval: 5s
      timeout: 5s
      retries: 30
    restart: unless-stopped
{{- else if eq .DBDriver "clickhouse" }}

  db:
    image: clickhouse/clickhouse-server:24.8-alpine
    container_name: {{.ProjectNameLower}}_db
    ports:
      - "${{"{"}}{{.ProjectNameUpper}}_DATABASE_PORT:-9001}:9000"   # native TCP
      - "${{"{"}}{{.ProjectNameUpper}}_DATABASE_HTTP_PORT:-8124}:8123"  # HTTP
    environment:
      CLICKHOUSE_DB: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_NAME:-{{.ProjectNameLower}}_dev}
      CLICKHOUSE_USER: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_USER:-default}
      CLICKHOUSE_PASSWORD: ${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD:-}
      CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT: 1
    ulimits:
      nofile:
        soft: 262144
        hard: 262144
    volumes:
      - db_data:/var/lib/clickhouse
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:8123/ping || exit 1"]
      interval: 5s
      timeout: 5s
      retries: 20
    restart: unless-stopped
{{- end }}

  # cache (redis) is active when EITHER the `cache` or `queue` profile
  # is enabled. Both profiles are needed because the asynqmon `queue`
  # service depends_on cache, and Compose requires a depended-upon
  # service to share its dependent's profile (or be unprofiled). See:
  # https://docs.docker.com/compose/how-tos/profiles/
  #
  # gofasta dev auto-activates both profiles; pass --no-cache /
  # --no-queue to opt out. With raw docker compose, start it on demand:
  #   docker compose --profile cache up -d
  #   docker compose --profile queue up -d   # also brings cache up
  cache:
    image: redis:7-alpine
    container_name: {{.ProjectNameLower}}_cache
    profiles: [cache, queue]
    ports:
      - "${REDIS_HOST_PORT:-6379}:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 2s
      timeout: 3s
      retries: 10
    restart: unless-stopped

  # queue (asynq monitoring UI) is profile-gated. The async queue
  # itself runs inside the app process via hibiken/asynq against redis;
  # this service is purely the web dashboard for inspecting queues.
  # Start it on demand with:
  #   gofasta dev --profile queue
  queue:
    image: hibiken/asynqmon:latest
    # hibiken/asynqmon publishes only a linux/amd64 manifest on Docker
    # Hub — there is no arm64 build. Pinning the platform makes Apple
    # Silicon (M-series) and other arm64 hosts run it under emulation
    # (Rosetta 2 on macOS) rather than fail the pull with
    # `no matching manifest for linux/arm64/v8`. Native amd64 hosts
    # (Intel Macs, Linux CI, Windows/WSL on Intel) are unaffected.
    platform: linux/amd64
    container_name: {{.ProjectNameLower}}_queue
    profiles: [queue]
    ports:
      - "${ASYNQMON_HOST_PORT:-8081}:8080"
    depends_on:
      cache:
        condition: service_healthy
    environment:
      - REDIS_ADDR=cache:6379
    restart: unless-stopped

volumes:
{{- if ne .DBDriver "sqlite" }}
  db_data:
{{- end }}
  go_modules:
  go_build_cache:

# {{.ProjectName}} Development Environment
# Usage: docker compose up
# That's it. No .env needed for basic startup.

services:
  app:
    build:
      context: .
      dockerfile: deployments/docker/dev.dockerfile
    container_name: {{.ProjectNameLower}}_app
    ports:
      - "${PORT:-8080}:${PORT:-8080}"
    volumes:
      - .:/{{.ProjectNameLower}}
      - go_modules:/go/pkg/mod
      - go_build_cache:/root/.cache/go-build
    environment:
      - PORT=${PORT:-8080}
      - GOFASTA_DATABASE_DRIVER=${{"{"}}GOFASTA_DATABASE_DRIVER:-postgres}
      - GOFASTA_DATABASE_HOST=db
      - GOFASTA_DATABASE_PORT=5432
      - GOFASTA_DATABASE_USER=${{"{"}}GOFASTA_DATABASE_USER:-{{.ProjectNameLower}}}
      - GOFASTA_DATABASE_PASSWORD=${{"{"}}GOFASTA_DATABASE_PASSWORD:-{{.ProjectNameLower}}}
      - GOFASTA_DATABASE_NAME=${{"{"}}GOFASTA_DATABASE_NAME:-{{.ProjectNameLower}}_dev}
      - GOFASTA_DATABASE_SSLMODE=disable
      - GOFASTA_LOG_LEVEL=${{"{"}}GOFASTA_LOG_LEVEL:-debug}
      - GOFASTA_LOG_FORMAT=${{"{"}}GOFASTA_LOG_FORMAT:-text}
    depends_on:
      db:
        condition: service_healthy
    restart: unless-stopped

  db:
    image: postgres:16-alpine
    container_name: {{.ProjectNameLower}}_db
    ports:
      - "${DB_HOST_PORT:-5433}:5432"
    environment:
      POSTGRES_USER: ${{"{"}}GOFASTA_DATABASE_USER:-{{.ProjectNameLower}}}
      POSTGRES_PASSWORD: ${{"{"}}GOFASTA_DATABASE_PASSWORD:-{{.ProjectNameLower}}}
      POSTGRES_DB: ${{"{"}}GOFASTA_DATABASE_NAME:-{{.ProjectNameLower}}_dev}
    volumes:
      - db_data:/var/lib/postgresql/data
    healthcheck:
      # pg_isready must target the actual database name — without -d it tries
      # to connect to a database named after the user, which is wrong whenever
      # POSTGRES_DB differs from POSTGRES_USER and fills the log with
      # "database <user> does not exist" FATALs until the retry budget is used
      # up (or forever, if the container restarts).
      test: ["CMD-SHELL", "pg_isready -U ${{"{"}}GOFASTA_DATABASE_USER:-{{.ProjectNameLower}}} -d ${{"{"}}GOFASTA_DATABASE_NAME:-{{.ProjectNameLower}}_dev}"]
      interval: 2s
      timeout: 5s
      retries: 10
    restart: unless-stopped

volumes:
  db_data:
  go_modules:
  go_build_cache:

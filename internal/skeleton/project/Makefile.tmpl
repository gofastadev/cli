.PHONY: dev up down serve build wire generate test test-integration lint lint-install fmt fmt-check vet preflight clean migrate migrate-up migrate-down seed init doctor{{if .GraphQL}} gqlgen{{end}}

# Pinned golangci-lint version. MUST match the version in
# .github/workflows/test.yml so a green local preflight predicts a green
# CI run. Bump both files together when upgrading the linter.
GOLANGCI_LINT_VERSION := v2.11.4
GOLANGCI_LINT := $(shell go env GOPATH)/bin/golangci-lint

# ──────────────────────────────────────────────
# Development (pick one)
# ──────────────────────────────────────────────
#
# Every target here is a thin wrapper over the `gofasta` CLI so `make` users
# and `gofasta` users run the same code path. If a target is broken, fix the
# CLI command — don't fix it in the Makefile.

# Run on host with Air hot reload (requires Go + a reachable database).
# Works with the db-in-Docker workflow: run `make up-db` first.
dev:
	gofasta dev

# Run everything in Docker (app + db in containers).
up:
	docker compose up --build

# Start only the database container (for use with `make dev`).
up-db:
	docker compose up db -d

down:
	docker compose down

# Run the HTTP server directly (no hot reload). Useful for profiling.
serve:
	gofasta serve

# ──────────────────────────────────────────────
# Build & Code Generation
# ──────────────────────────────────────────────

build:
	go build -o ./tmp/main ./app/main/

wire:
	gofasta wire

generate:
	go generate ./...

{{- if .GraphQL}}
gqlgen:
	go tool gqlgen generate
{{- end}}

# ──────────────────────────────────────────────
# Testing
# ──────────────────────────────────────────────

test:
	go test ./... -short -v

test-integration:
	go test ./... -run Integration -v

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────

migrate: migrate-up

migrate-up:
	gofasta migrate up

migrate-down:
	gofasta migrate down

seed:
	gofasta seed

# ──────────────────────────────────────────────
# Setup & diagnostics
# ──────────────────────────────────────────────

init:
	gofasta init

doctor:
	gofasta doctor

# ──────────────────────────────────────────────
# Lint, format, and preflight
# ──────────────────────────────────────────────

# Format every Go file (gofmt -s rewrites in place).
fmt:
	gofmt -s -w .

# Verify gofmt has nothing to change. Fails if any file would be rewritten —
# which is what CI enforces. Portable across /bin/sh and bash.
fmt-check:
	@out=$$(gofmt -s -l .); \
	if [ -n "$$out" ]; then \
		echo "gofmt issues in:"; echo "$$out"; \
		echo "run 'make fmt' to fix"; \
		exit 1; \
	fi

# go vet across every package.
vet:
	go vet ./...

# Install golangci-lint at the version pinned above. Idempotent — only
# (re)installs if the on-PATH version differs.
lint-install:
	@if ! $(GOLANGCI_LINT) --version 2>/dev/null | grep -q "$(GOLANGCI_LINT_VERSION:v%=%)"; then \
		echo "Installing golangci-lint $(GOLANGCI_LINT_VERSION)..."; \
		go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@$(GOLANGCI_LINT_VERSION); \
	fi

# Run golangci-lint with the pinned version + the project's .golangci.yml.
lint: lint-install
	$(GOLANGCI_LINT) run

# Preflight — the full sequence CI runs, in order. A task is not done
# until this is green. Mirrors gofasta's own preflight philosophy: if a
# step CI runs is skipped locally, that's how broken code reaches main.
#
# Order is intentional: fmt-check first (cheapest, catches the most
# common slip), then vet, then lint (the heavy step), then race tests,
# then a clean build.
preflight: fmt-check vet lint
	go test -race ./...
	go build ./...
	@echo ""
	@echo "  ✓ preflight green — safe to commit."

clean:
	rm -rf ./tmp
	go clean

.PHONY: dev up down serve build wire generate test test-integration lint clean migrate migrate-up migrate-down seed init doctor{{if .GraphQL}} gqlgen{{end}}

# ──────────────────────────────────────────────
# Development (pick one)
# ──────────────────────────────────────────────
#
# Every target here is a thin wrapper over the `gofasta` CLI so `make` users
# and `gofasta` users run the same code path. If a target is broken, fix the
# CLI command — don't fix it in the Makefile.

# Run on host with Air hot reload (requires Go + a reachable database).
# Works with the db-in-Docker workflow: run `make up-db` first.
dev:
	gofasta dev

# Run everything in Docker (app + db in containers).
up:
	docker compose up --build

# Start only the database container (for use with `make dev`).
up-db:
	docker compose up db -d

down:
	docker compose down

# Run the HTTP server directly (no hot reload). Useful for profiling.
serve:
	gofasta serve

# ──────────────────────────────────────────────
# Build & Code Generation
# ──────────────────────────────────────────────

build:
	go build -o ./tmp/main ./app/main/

wire:
	gofasta wire

generate:
	go generate ./...

{{- if .GraphQL}}
gqlgen:
	go tool gqlgen generate
{{- end}}

# ──────────────────────────────────────────────
# Testing
# ──────────────────────────────────────────────

test:
	go test ./... -short -v

test-integration:
	go test ./... -run Integration -v

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────

migrate: migrate-up

migrate-up:
	gofasta migrate up

migrate-down:
	gofasta migrate down

seed:
	gofasta seed

# ──────────────────────────────────────────────
# Setup & diagnostics
# ──────────────────────────────────────────────

init:
	gofasta init

doctor:
	gofasta doctor

# ──────────────────────────────────────────────
# Lint & Cleanup
# ──────────────────────────────────────────────

lint:
	golangci-lint run

clean:
	rm -rf ./tmp
	go clean

# {{.ProjectName}} Environment Configuration
# Copy this to .env and customize as needed.
# All values have sensible defaults — you can start with an empty .env file.

# Server
PORT=8080

# Database — shared between host-run and docker-run flows.
#
# DEFAULTS ARE SET UP FOR OPTION B (`gofasta dev` on the host, db in Docker):
#   HOST=localhost and PORT=5433 match the port the docker-compose db service
#   publishes to the host via DB_HOST_PORT. `gofasta dev` loads this .env
#   before launching Air, so the host-running app connects to the dockerized
#   db on localhost:5433 out of the box.
#
# For OPTION A (`docker compose up -d` — everything in Docker), compose.yaml
# overrides HOST and PORT in the app container to `db:5432` (the Docker
# network address), so these values are ignored inside the container.
#
# For OPTION C (everything on host with your own postgres), change HOST/PORT
# below to wherever your db lives — typically `localhost:5432`.
GOFASTA_DATABASE_DRIVER=postgres
GOFASTA_DATABASE_HOST=localhost
GOFASTA_DATABASE_PORT=5433
GOFASTA_DATABASE_USER={{.ProjectNameLower}}
GOFASTA_DATABASE_PASSWORD={{.ProjectNameLower}}
GOFASTA_DATABASE_NAME={{.ProjectNameLower}}_dev
DB_HOST_PORT=5433

# Logging
GOFASTA_LOG_LEVEL=debug
GOFASTA_LOG_FORMAT=text

# Email (configure when needed)
# GOFASTA_EMAIL_PROVIDER=smtp
# GOFASTA_EMAIL_FROM_NAME=My App
# GOFASTA_EMAIL_FROM_ADDRESS=noreply@example.com
# GOFASTA_EMAIL_SMTP_HOST=smtp.gmail.com

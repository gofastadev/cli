# {{.ProjectName}} Environment Configuration
# Copy this to .env and customize as needed.
# All values have sensible defaults — you can start with an empty .env file.

# Server
PORT=8080

# Database — shared between host-run and docker-run flows.
#
# DEFAULTS ARE SET UP FOR OPTION B (`gofasta dev` on the host, db in Docker):
#   HOST=localhost and PORT=5433 match the port the docker-compose db service
#   publishes to the host. `gofasta dev` loads this .env before launching
#   Air, so the host-running app connects to the dockerized db on
#   localhost:5433 out of the box.
#
#   The SAME {{.ProjectNameUpper}}_DATABASE_PORT value drives compose.yaml's
#   host-side port mapping for the db service — one variable, one source
#   of truth. (Inside the app container, compose overrides this to 5432,
#   the postgres container's internal port; see compose.yaml.)
#
# For OPTION A (everything in Docker — including Air), use:
#   gofasta dev --services all
# or, equivalently, raw compose:
#   docker compose up -d
# In both cases, compose.yaml overrides HOST and PORT in the app container
# to `db:5432` (the Docker network address), so these values are ignored
# inside the container.
#
# For OPTION C (everything on host with your own postgres), change HOST/PORT
# below to wherever your db lives — typically `localhost:5432`.
{{.ProjectNameUpper}}_DATABASE_DRIVER=postgres
{{.ProjectNameUpper}}_DATABASE_HOST=localhost
{{.ProjectNameUpper}}_DATABASE_PORT=5433
{{.ProjectNameUpper}}_DATABASE_USER={{.ProjectNameLower}}
{{.ProjectNameUpper}}_DATABASE_PASSWORD={{.ProjectNameLower}}
{{.ProjectNameUpper}}_DATABASE_NAME={{.ProjectNameLower}}_dev

# Logging
{{.ProjectNameUpper}}_LOG_LEVEL=debug
{{.ProjectNameUpper}}_LOG_FORMAT=text

# Cache (Redis) — `gofasta dev` auto-activates the `cache` compose
# profile by default; pass --no-cache to skip. With raw docker compose,
# start it on demand with `docker compose --profile cache up -d`.
#
# Host-run app talks to the dockerized redis on localhost:REDIS_HOST_PORT.
# Inside the app container (compose profile), REDIS_ADDR=cache:6379.
{{.ProjectNameUpper}}_REDIS_URL=redis://localhost:6379/0
REDIS_HOST_PORT=6379

# Queue dashboard (asynqmon) — `gofasta dev` auto-activates the `queue`
# compose profile by default (which also brings cache up since the
# dashboard depends on it). Pass --no-queue to skip. Serves the Asynq
# monitoring UI on :ASYNQMON_HOST_PORT.
ASYNQMON_HOST_PORT=8081

# Email (configure when needed)
# {{.ProjectNameUpper}}_EMAIL_PROVIDER=smtp
# {{.ProjectNameUpper}}_EMAIL_FROM_NAME=My App

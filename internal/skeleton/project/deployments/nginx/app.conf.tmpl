# {{.ProjectName}} Nginx Reverse Proxy
# Works with both Docker and bare metal deployments.
#
# Setup:
#   1. Replace api.example.com with your domain
#   2. Copy to: /etc/nginx/sites-available/{{.ProjectNameLower}}.conf
#   3. Symlink: ln -s /etc/nginx/sites-available/{{.ProjectNameLower}}.conf /etc/nginx/sites-enabled/
#   4. Test: nginx -t
#   5. Reload: systemctl reload nginx
#
# For HTTPS, use certbot:
#   certbot --nginx -d api.example.com

upstream {{.ProjectNameLower}}_backend {
    server 127.0.0.1:8080;
    keepalive 32;
}

server {
    listen 80;
    server_name api.example.com;    # Replace with your domain

    # Redirect HTTP to HTTPS (uncomment after certbot setup)
    # return 301 https://$host$request_uri;

    location / {
        proxy_pass http://{{.ProjectNameLower}}_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header Connection "";

        # Timeouts
        proxy_connect_timeout 10s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;

        # Buffering
        proxy_buffering on;
        proxy_buffer_size 8k;
        proxy_buffers 8 8k;
    }

    # GraphQL playground — allow larger payloads
    location /graphql {
        proxy_pass http://{{.ProjectNameLower}}_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 10m;
    }

    # Health check endpoint (for load balancers)
    location /health {
        proxy_pass http://{{.ProjectNameLower}}_backend;
        access_log off;
    }

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
}

# .github/workflows/test.yml
# Copy this file to .github/workflows/test.yml
#
# Runs the project's full preflight on every push and PR. The preflight
# target (in the project's Makefile) chains: gofmt check, go vet,
# golangci-lint with the pinned version, race tests, and a build —
# mirroring gofasta's own development workflow so a green local
# preflight predicts a green CI run.
#
# The pinned golangci-lint version below MUST match GOLANGCI_LINT_VERSION
# in the Makefile. Bump them together when upgrading.

name: Test

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main, develop]

jobs:
  preflight:
    runs-on: ubuntu-latest

    services:
      postgres:
        image: postgres:18-alpine
        env:
          POSTGRES_USER: {{.ProjectNameLower}}
          POSTGRES_PASSWORD: {{.ProjectNameLower}}
          POSTGRES_DB: {{.ProjectNameLower}}_test
        ports:
          - 5432:5432
        options: >-
          --health-cmd "pg_isready -U {{.ProjectNameLower}}"
          --health-interval 5s
          --health-timeout 5s
          --health-retries 5

    env:
      {{.ProjectNameUpper}}_DATABASE_HOST: localhost
      {{.ProjectNameUpper}}_DATABASE_PORT: "5432"
      {{.ProjectNameUpper}}_DATABASE_USER: {{.ProjectNameLower}}
      {{.ProjectNameUpper}}_DATABASE_PASSWORD: {{.ProjectNameLower}}
      {{.ProjectNameUpper}}_DATABASE_NAME: {{.ProjectNameLower}}_test

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-go@v5
        with:
          go-version: "1.25"

      - name: Install dependencies
        run: go mod download

      # Install the linter at the version the Makefile pins, so CI and a
      # developer's `make preflight` agree on the ruleset.
      - name: Install golangci-lint
        uses: golangci/golangci-lint-action@v8
        with:
          version: v2.11.4
          install-mode: binary
          args: --version

      - name: Preflight
        run: make preflight

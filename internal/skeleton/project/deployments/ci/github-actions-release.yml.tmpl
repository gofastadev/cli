# .github/workflows/release.yml
# Builds and publishes binaries on every tag.
#
# Usage: git tag v1.0.0 && git push origin v1.0.0
# Copy this file to .github/workflows/release.yml

name: Release

on:
  push:
    tags:
      - "v*"

permissions:
  contents: write

jobs:
  release:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - uses: actions/setup-go@v5
        with:
          go-version: "1.25"

      - name: Build binaries
        run: |
          mkdir -p dist

          # Linux amd64
          GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o dist/{{.ProjectNameLower}}-linux-amd64 ./app/main
          # Linux arm64
          GOOS=linux GOARCH=arm64 go build -ldflags="-s -w" -o dist/{{.ProjectNameLower}}-linux-arm64 ./app/main
          # macOS amd64 (Intel)
          GOOS=darwin GOARCH=amd64 go build -ldflags="-s -w" -o dist/{{.ProjectNameLower}}-darwin-amd64 ./app/main
          # macOS arm64 (Apple Silicon)
          GOOS=darwin GOARCH=arm64 go build -ldflags="-s -w" -o dist/{{.ProjectNameLower}}-darwin-arm64 ./app/main
          # Windows amd64
          GOOS=windows GOARCH=amd64 go build -ldflags="-s -w" -o dist/{{.ProjectNameLower}}-windows-amd64.exe ./app/main

          # Create checksums
          cd dist && sha256sum * > checksums.txt

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v2
        with:
          files: dist/*
          generate_release_notes: true

# .github/workflows/deploy-azure.yml
# Deploy to Azure Container Apps via ACR.
# Copy to .github/workflows/ and set GitHub secrets:
#   AZURE_CREDENTIALS (service principal JSON), ACR_LOGIN_SERVER, ACR_USERNAME, ACR_PASSWORD,
#   AZURE_RESOURCE_GROUP, AZURE_CONTAINER_APP

name: Deploy to Azure

on:
  push:
    branches: [main]

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Login to Azure
        uses: azure/login@v2
        with:
          creds: ${{"{{"}} secrets.AZURE_CREDENTIALS {{"}}"}}

      - name: Login to ACR
        uses: azure/docker-login@v2
        with:
          login-server: ${{"{{"}} secrets.ACR_LOGIN_SERVER {{"}}"}}
          username: ${{"{{"}} secrets.ACR_USERNAME {{"}}"}}
          password: ${{"{{"}} secrets.ACR_PASSWORD {{"}}"}}

      - name: Build and push Docker image
        env:
          IMAGE: ${{"{{"}} secrets.ACR_LOGIN_SERVER {{"}}"}}/{{.ProjectNameLower}}
        run: |
          docker build -t $IMAGE:${{"{{"}} github.sha {{"}}"}} -t $IMAGE:latest .
          docker push $IMAGE:${{"{{"}} github.sha {{"}}"}}
          docker push $IMAGE:latest

      - name: Deploy to Container Apps
        run: |
          az containerapp update \
            --name ${{"{{"}} secrets.AZURE_CONTAINER_APP {{"}}"}} \
            --resource-group ${{"{{"}} secrets.AZURE_RESOURCE_GROUP {{"}}"}} \
            --image ${{"{{"}} secrets.ACR_LOGIN_SERVER {{"}}"}}/{{.ProjectNameLower}}:${{"{{"}} github.sha {{"}}"}}

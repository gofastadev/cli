# {{.ProjectName}} Development Dockerfile
# Used by compose.yaml — mounts source code, runs air for hot reload.

FROM golang:1.25.0-alpine

RUN apk add --no-cache git curl bash

# Install migrate CLI with all database drivers
RUN go install -tags 'postgres mysql sqlite3 sqlserver clickhouse' \
    github.com/golang-migrate/migrate/v4/cmd/migrate@v4.18.1

WORKDIR /{{.ProjectNameLower}}

COPY go.mod go.sum ./
RUN go mod download

# Inside a container the app must listen on all interfaces so the
# published port is reachable from the host. The framework default is
# loopback — fine on the host (skips macOS firewall popup during Air
# rebuilds), wrong inside a container.
ENV {{.ProjectNameUpper}}_SERVER_HOST=0.0.0.0

EXPOSE ${PORT:-8080}

CMD ["sh", "-c", "\
    echo '==> Running migrations...' && \
    migrate -database \"${{"{"}}{{.ProjectNameUpper}}_DATABASE_DRIVER:-postgres}://${{"{"}}{{.ProjectNameUpper}}_DATABASE_USER}:${{"{"}}{{.ProjectNameUpper}}_DATABASE_PASSWORD}@${{"{"}}{{.ProjectNameUpper}}_DATABASE_HOST}:${{"{"}}{{.ProjectNameUpper}}_DATABASE_PORT}/${{"{"}}{{.ProjectNameUpper}}_DATABASE_NAME}?sslmode=${{"{"}}{{.ProjectNameUpper}}_DATABASE_SSLMODE:-disable}\" -path db/migrations up 2>&1 || echo '==> Migrations: nothing to apply' && \
    echo '==> Starting dev server with hot reload...' && \
    echo '    REST:       http://localhost:'${PORT:-8080} && \
{{- if .GraphQL}}
    echo '    GraphQL:    http://localhost:'${PORT:-8080}'/graphql' && \
    echo '    Playground: http://localhost:'${PORT:-8080}'/graphql-playground' && \
{{- end}}
    go tool air \
"]

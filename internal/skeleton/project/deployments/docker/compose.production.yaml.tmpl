# {{.ProjectName}} Production Docker Compose
# Usage: docker compose -f deployments/docker/compose.production.yaml up -d
# Works on any VPS, AWS EC2, GCP Compute Engine, Azure VM.

services:
  app:
    build:
      context: ../..
      dockerfile: Dockerfile
    container_name: ${PROJECT_NAME:-{{.ProjectNameLower}}}_app
    ports:
      - "${PORT:-8080}:8080"
    environment:
      - GOFASTA_DATABASE_DRIVER=${{"{"}}GOFASTA_DATABASE_DRIVER:-postgres}
      - GOFASTA_DATABASE_HOST=db
      - GOFASTA_DATABASE_PORT=5432
      - GOFASTA_DATABASE_USER=${{"{"}}GOFASTA_DATABASE_USER}
      - GOFASTA_DATABASE_PASSWORD=${{"{"}}GOFASTA_DATABASE_PASSWORD}
      - GOFASTA_DATABASE_NAME=${{"{"}}GOFASTA_DATABASE_NAME}
      - GOFASTA_DATABASE_SSLMODE=${{"{"}}GOFASTA_DATABASE_SSLMODE:-disable}
      - GOFASTA_LOG_LEVEL=${{"{"}}GOFASTA_LOG_LEVEL:-info}
      - GOFASTA_LOG_FORMAT=${{"{"}}GOFASTA_LOG_FORMAT:-json}
      - GOFASTA_EMAIL_PROVIDER=${{"{"}}GOFASTA_EMAIL_PROVIDER:-smtp}
      - GOFASTA_EMAIL_FROM_NAME=${{"{"}}GOFASTA_EMAIL_FROM_NAME}
      - GOFASTA_EMAIL_FROM_ADDRESS=${{"{"}}GOFASTA_EMAIL_FROM_ADDRESS}
    depends_on:
      db:
        condition: service_healthy
    restart: always
    deploy:
      resources:
        limits:
          memory: 512M

  db:
    image: postgres:16-alpine
    container_name: ${PROJECT_NAME:-{{.ProjectNameLower}}}_db
    environment:
      POSTGRES_USER: ${{"{"}}GOFASTA_DATABASE_USER}
      POSTGRES_PASSWORD: ${{"{"}}GOFASTA_DATABASE_PASSWORD}
      POSTGRES_DB: ${{"{"}}GOFASTA_DATABASE_NAME}
    volumes:
      - db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${{"{"}}GOFASTA_DATABASE_USER}"]
      interval: 5s
      timeout: 5s
      retries: 5
    restart: always
    deploy:
      resources:
        limits:
          memory: 256M

volumes:
  db_data:

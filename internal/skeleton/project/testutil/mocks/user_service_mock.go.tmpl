// real interface; tests use errors.Is to assert on sentinel errors.
type MockUserService struct {
	mock.Mock
}

func (m *MockUserService) List(ctx context.Context, filter services.ListUsersFilter) ([]*models.User, int64, error) {
	args := m.Called(ctx, filter)
	if args.Get(0) == nil {
		return nil, args.Get(1).(int64), args.Error(2)
	}
	return args.Get(0).([]*models.User), args.Get(1).(int64), args.Error(2)
}


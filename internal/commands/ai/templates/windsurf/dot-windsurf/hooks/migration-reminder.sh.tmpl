#!/usr/bin/env bash
set -euo pipefail
# Cascade post_write_code hook. Reminds the agent to write a
# migration when a GORM model file is edited.

path=$(jq -r '.tool_info.file_path // ""' 2>/dev/null || true)

case "$path" in
  *app/models/*.go)
    echo "Reminder: you edited a GORM model. Write a matching migration pair in db/migrations/ (or run \`gofasta g migration <Name>\`)."
    ;;
esac
